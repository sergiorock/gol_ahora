# Ignorar bundler config
/.bundle

# Variables de entorno
/.env*
!/.env*.erb
!/.env.example

# Logs
/log/*
!/log/.keep

# Temporales
/tmp/*
!/tmp/.keep
!/tmp/pids/
!/tmp/pids/.keep
!/tmp/storage/
!/tmp/storage/.keep

# Storage (archivos subidos)
/storage/*
!/storage/.keep

# Assets compilados
/public/assets
/app/assets/builds/*
!/app/assets/builds/.keep

# Credenciales y claves
/config/master.key
/config/credentials/*.key

# Node
/node_modules/
/yarn-error.log

# Claude Code
/.claude/
/CLAUDE.md
/PLAN.md

# Sistema operativo
.DS_Store
Thumbs.db
