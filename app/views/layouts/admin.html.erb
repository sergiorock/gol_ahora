<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= content_for(:title) || "Admin — Gol Ahora" %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/@tabler/core@1.0.0-beta20/dist/css/tabler.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/js/tom-select.complete.min.js"></script>
    <%= stylesheet_link_tag :app %>
    <style>
      :root {
        --tblr-primary:         #ff6b35;
        --tblr-primary-rgb:     255, 107, 53;
        --tblr-primary-lt:      rgba(255, 107, 53, 0.1);
        --tblr-link-color:      #ff6b35;
        --tblr-link-hover-color:#e3521d;
      }
      .btn-primary                          { background-color:#ff6b35 !important; border-color:#ff6b35 !important; }
      .btn-primary:hover                    { background-color:#e3521d !important; border-color:#e3521d !important; }
      .navbar-vertical .nav-link.active     { color:#ff8a5c !important; background-color:rgba(255,107,53,.12) !important; }
      .navbar-vertical .nav-link:hover      { color:#ff8a5c !important; }
      .bg-primary                           { background-color:#ff6b35 !important; }
      .text-primary                         { color:#ff6b35 !important; }
      .form-control:focus, .form-select:focus { border-color:#ff6b35; box-shadow:0 0 0 .2rem rgba(255,107,53,.15); }
      .avatar.bg-primary-lt                 { background-color:rgba(255,107,53,.15) !important; color:#ff6b35 !important; }
    </style>
  </head>
  <body class="antialiased">
    <div class="wrapper">

      <%# Sidebar %>
      <aside class="navbar navbar-vertical navbar-expand-lg" data-bs-theme="dark">
        <div class="container-fluid">
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#sidebarMenu">
            <span class="navbar-toggler-icon"></span>
          </button>
          <h1 class="navbar-brand navbar-brand-autodark">
            <%= link_to root_path do %>
              <canvas id="logo-ball-canvas" style="vertical-align:middle; margin-right:5px;"></canvas><span class="text-white fw-bold">Gol Ahora</span>
            <% end %>
          </h1>
          <div class="collapse navbar-collapse" id="sidebarMenu">
            <ul class="navbar-nav pt-lg-3">
              <li class="nav-item">
                <%= link_to admin_root_path, class: "nav-link #{current_page?(admin_root_path) ? 'active' : ''}" do %>
                  <span class="nav-link-icon"><i class="ti ti-dashboard"></i></span>
                  <span class="nav-link-title">Dashboard</span>
                <% end %>
              </li>

              <li class="nav-item mt-2">
                <span class="nav-link text-muted small text-uppercase fw-bold">Usuarios</span>
              </li>
              <li class="nav-item">
                <%= link_to admin_users_path, class: "nav-link #{controller_name == 'users' ? 'active' : ''}" do %>
                  <span class="nav-link-icon"><i class="ti ti-users"></i></span>
                  <span class="nav-link-title">Usuarios</span>
                <% end %>
              </li>

              <li class="nav-item mt-2">
                <span class="nav-link text-muted small text-uppercase fw-bold">Canchas</span>
              </li>
              <li class="nav-item">
                <%= link_to admin_court_types_path, class: "nav-link #{controller_name == 'court_types' ? 'active' : ''}" do %>
                  <span class="nav-link-icon"><i class="ti ti-ball-football"></i></span>
                  <span class="nav-link-title">Tipos de Cancha</span>
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to admin_courts_path, class: "nav-link #{controller_name == 'courts' ? 'active' : ''}" do %>
                  <span class="nav-link-icon"><i class="ti ti-map"></i></span>
                  <span class="nav-link-title">Canchas</span>
                <% end %>
              </li>

              <li class="nav-item mt-2">
                <span class="nav-link text-muted small text-uppercase fw-bold">Reservas</span>
              </li>
              <li class="nav-item">
                <%= link_to admin_reservations_path, class: "nav-link #{controller_name == 'reservations' ? 'active' : ''}" do %>
                  <span class="nav-link-icon"><i class="ti ti-calendar"></i></span>
                  <span class="nav-link-title">Reservas</span>
                <% end %>
              </li>

              <li class="nav-item mt-2">
                <span class="nav-link text-muted small text-uppercase fw-bold">Finanzas</span>
              </li>
              <li class="nav-item">
                <%= link_to new_admin_walkin_path, class: "nav-link #{controller_name == 'walkins' ? 'active' : ''}" do %>
                  <span class="nav-link-icon"><i class="ti ti-run"></i></span>
                  <span class="nav-link-title">Registro presencial</span>
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to admin_charges_path, class: "nav-link #{controller_name == 'charges' ? 'active' : ''}" do %>
                  <span class="nav-link-icon"><i class="ti ti-cash"></i></span>
                  <span class="nav-link-title">Cobros</span>
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to admin_discounts_path, class: "nav-link #{controller_name == 'discounts' ? 'active' : ''}" do %>
                  <span class="nav-link-icon"><i class="ti ti-discount"></i></span>
                  <span class="nav-link-title">Descuentos</span>
                <% end %>
              </li>

              <li class="nav-item mt-2">
                <span class="nav-link text-muted small text-uppercase fw-bold">Competencias</span>
              </li>
              <li class="nav-item">
                <%= link_to admin_leagues_path, class: "nav-link #{controller_name == 'leagues' ? 'active' : ''}" do %>
                  <span class="nav-link-icon"><i class="ti ti-trophy"></i></span>
                  <span class="nav-link-title">Ligas</span>
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to admin_tournaments_path, class: "nav-link #{controller_name == 'tournaments' ? 'active' : ''}" do %>
                  <span class="nav-link-icon"><i class="ti ti-tournament"></i></span>
                  <span class="nav-link-title">Torneos</span>
                <% end %>
              </li>

              <li class="nav-item mt-2">
                <span class="nav-link text-muted small text-uppercase fw-bold">Academia</span>
              </li>
              <li class="nav-item">
                <%= link_to admin_personal_deportivos_path, class: "nav-link #{controller_name == 'personal_deportivos' ? 'active' : ''}" do %>
                  <span class="nav-link-icon"><i class="ti ti-id-badge"></i></span>
                  <span class="nav-link-title">Personal Deportivo</span>
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to admin_clases_path, class: "nav-link #{controller_name == 'clases' ? 'active' : ''}" do %>
                  <span class="nav-link-icon"><i class="ti ti-school"></i></span>
                  <span class="nav-link-title">Clases</span>
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to admin_entrenamientos_path, class: "nav-link #{controller_name == 'entrenamientos' ? 'active' : ''}" do %>
                  <span class="nav-link-icon"><i class="ti ti-barbell"></i></span>
                  <span class="nav-link-title">Entrenamientos</span>
                <% end %>
              </li>

              <li class="nav-item mt-2">
                <span class="nav-link text-muted small text-uppercase fw-bold">Reportes</span>
              </li>
              <li class="nav-item">
                <%= link_to reservas_admin_reportes_path, class: "nav-link #{controller_name == 'reportes' && action_name == 'reservas' ? 'active' : ''}" do %>
                  <span class="nav-link-icon"><i class="ti ti-calendar-stats"></i></span>
                  <span class="nav-link-title">Reservas</span>
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to cobros_admin_reportes_path, class: "nav-link #{controller_name == 'reportes' && action_name == 'cobros' ? 'active' : ''}" do %>
                  <span class="nav-link-icon"><i class="ti ti-report-money"></i></span>
                  <span class="nav-link-title">Cobros</span>
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to ocupacion_admin_reportes_path, class: "nav-link #{controller_name == 'reportes' && action_name == 'ocupacion' ? 'active' : ''}" do %>
                  <span class="nav-link-icon"><i class="ti ti-chart-bar"></i></span>
                  <span class="nav-link-title">Ocupación canchas</span>
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to tipos_cancha_admin_reportes_path, class: "nav-link #{controller_name == 'reportes' && action_name == 'tipos_cancha' ? 'active' : ''}" do %>
                  <span class="nav-link-icon"><i class="ti ti-list-details"></i></span>
                  <span class="nav-link-title">Tipos de cancha</span>
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to asistencias_clases_admin_reportes_path, class: "nav-link #{controller_name == 'reportes' && action_name == 'asistencias_clases' ? 'active' : ''}" do %>
                  <span class="nav-link-icon"><i class="ti ti-checklist"></i></span>
                  <span class="nav-link-title">Asist. clases</span>
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to asistencias_entrenamientos_admin_reportes_path, class: "nav-link #{controller_name == 'reportes' && action_name == 'asistencias_entrenamientos' ? 'active' : ''}" do %>
                  <span class="nav-link-icon"><i class="ti ti-checklist"></i></span>
                  <span class="nav-link-title">Asist. entrenamientos</span>
                <% end %>
              </li>
            </ul>

            <div class="mt-auto pt-3 border-top">
              <div class="d-flex align-items-center px-3 py-2">
                <div class="flex-fill">
                  <div class="fw-semibold text-white small"><%= current_user.full_name %></div>
                  <div class="text-muted small"><%= current_user.email %></div>
                </div>
                <%= button_to destroy_user_session_path, method: :delete, class: "btn btn-ghost-light btn-sm", title: "Cerrar sesión" do %>
                  <i class="ti ti-logout"></i>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </aside>

      <%# Contenido principal %>
      <div class="page-wrapper">
        <div class="page-header d-print-none">
          <div class="container-xl">
            <div class="row g-2 align-items-center">
              <div class="col">
                <h2 class="page-title"><%= content_for(:page_title) { "Dashboard" } %></h2>
              </div>
              <% if content_for?(:header_actions) %>
                <div class="col-auto ms-auto d-flex gap-2 align-items-center flex-wrap">
                  <%= yield :header_actions %>
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <div class="page-body">
          <div class="container-xl">
            <% if notice %>
              <div class="alert alert-primary alert-dismissible mb-3" role="alert">
                <%= notice %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
              </div>
            <% end %>
            <% if alert %>
              <div class="alert alert-danger alert-dismissible mb-3" role="alert">
                <%= alert %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
              </div>
            <% end %>

            <%= yield %>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/@tabler/core@1.0.0-beta20/dist/js/tabler.min.js"></script>
    <script>
      (() => {
        const initCountryTomSelect = () => {
          if (typeof TomSelect === 'undefined') return;

          document.querySelectorAll('select.country-tomselect').forEach((element) => {
            if (element.tomselect) return;

            new TomSelect(element, {
              allowEmptyOption: true,
              searchField: ['text'],
              placeholder: element.dataset.placeholder || '',
              render: {
                no_results: () => '<div class="no-results px-3 py-2 text-muted">Sin resultados</div>'
              }
            });
          });
        };

        document.addEventListener('DOMContentLoaded', initCountryTomSelect);
        document.addEventListener('turbo:load', initCountryTomSelect);
      })();
    </script>
    <script>
      (function() {
        function initBall() {
          const canvas = document.getElementById('logo-ball-canvas');
          if (!canvas || canvas._ballInit) return;
          canvas._ballInit = true;

          const dpr  = window.devicePixelRatio || 1;
          const SIZE = 28;
          canvas.width  = SIZE * dpr;
          canvas.height = SIZE * dpr;
          canvas.style.width  = SIZE + 'px';
          canvas.style.height = SIZE + 'px';

          const ctx = canvas.getContext('2d');
          ctx.scale(dpr, dpr);

          const cx = SIZE / 2, cy = SIZE / 2, R = SIZE / 2 - 1.5;

          // Centros de los 12 pentágonos de un balón (vértices del icosaedro, normalizados)
          const phi  = (1 + Math.sqrt(5)) / 2;
          const norm = Math.sqrt(1 + phi * phi);
          const patches = [
            [ 0,          1/norm,   phi/norm],
            [ 0,          1/norm,  -phi/norm],
            [ 0,         -1/norm,   phi/norm],
            [ 0,         -1/norm,  -phi/norm],
            [ 1/norm,   phi/norm,   0],
            [-1/norm,   phi/norm,   0],
            [ 1/norm,  -phi/norm,   0],
            [-1/norm,  -phi/norm,   0],
            [ phi/norm,  0,         1/norm],
            [-phi/norm,  0,         1/norm],
            [ phi/norm,  0,        -1/norm],
            [-phi/norm,  0,        -1/norm],
          ];

          let t = 0;
          const TILT = 0.3; // inclinación fija en X para que parezca real

          function rotate(x, y, z, ay) {
            // Y axis rotation
            const x1 =  x * Math.cos(ay) + z * Math.sin(ay);
            const z1 = -x * Math.sin(ay) + z * Math.cos(ay);
            // X axis tilt (fijo)
            const y2 =  y * Math.cos(TILT) - z1 * Math.sin(TILT);
            const z2 =  y * Math.sin(TILT) + z1 * Math.cos(TILT);
            return [x1, y2, z2];
          }

          function draw() {
            ctx.clearRect(0, 0, SIZE, SIZE);

            // Base esférica con gradiente de iluminación fija
            const grad = ctx.createRadialGradient(cx - R*0.35, cy - R*0.35, R*0.05, cx, cy, R);
            grad.addColorStop(0,   '#ffffff');
            grad.addColorStop(0.3, '#eeeeee');
            grad.addColorStop(0.7, '#c0c0c0');
            grad.addColorStop(1,   '#888888');

            ctx.save();
            ctx.beginPath();
            ctx.arc(cx, cy, R, 0, Math.PI * 2);
            ctx.fillStyle = grad;
            ctx.fill();
            ctx.restore();

            // Parches rotando (recortados dentro de la esfera)
            ctx.save();
            ctx.beginPath();
            ctx.arc(cx, cy, R, 0, Math.PI * 2);
            ctx.clip();

            patches.forEach(function([px, py, pz]) {
              const [rx, ry, rz] = rotate(px, py, pz, t);
              if (rz <= 0) return; // solo hemisferio frontal

              const x2d    = cx + rx * R;
              const y2d    = cy - ry * R;
              const patchR = R * 0.28 * Math.pow(rz, 0.3);
              const alpha  = 0.85 * rz;

              ctx.beginPath();
              ctx.arc(x2d, y2d, patchR, 0, Math.PI * 2);
              ctx.fillStyle = 'rgba(20,20,20,' + alpha + ')';
              ctx.fill();
            });

            ctx.restore();

            // Borde
            ctx.beginPath();
            ctx.arc(cx, cy, R, 0, Math.PI * 2);
            ctx.strokeStyle = 'rgba(0,0,0,0.3)';
            ctx.lineWidth   = 1;
            ctx.stroke();

            // Reflejo de luz (fijo, la luz no rota con la pelota)
            ctx.save();
            ctx.beginPath();
            ctx.arc(cx, cy, R, 0, Math.PI * 2);
            ctx.clip();
            const shine = ctx.createRadialGradient(cx - R*0.28, cy - R*0.3, 0, cx - R*0.1, cy - R*0.1, R*0.55);
            shine.addColorStop(0,   'rgba(255,255,255,0.7)');
            shine.addColorStop(0.4, 'rgba(255,255,255,0.15)');
            shine.addColorStop(1,   'rgba(255,255,255,0)');
            ctx.fillStyle = shine;
            ctx.fillRect(0, 0, SIZE, SIZE);
            ctx.restore();

            t += 0.022;
            requestAnimationFrame(draw);
          }

          draw();
        }

        document.addEventListener('DOMContentLoaded', initBall);
        document.addEventListener('turbo:load',       initBall);
      })();
    </script>
  </body>
</html>
