<div class="min-h-screen flex items-center justify-center px-4 pt-16">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <h1 class="font-display text-5xl text-white mb-2">BIENVENIDO</h1>
      <p class="text-white/50">Iniciá sesión para continuar</p>
    </div>

    <div class="bg-white/5 border border-white/10 rounded-2xl p-8">
      <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-white/70 mb-1.5">Email</label>
            <%= f.input_field :email, autofocus: true, autocomplete: "email",
                class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors",
                placeholder: "tu@email.com" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-white/70 mb-1.5">Contraseña</label>
            <%= f.input_field :password, autocomplete: "current-password",
                class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors",
                placeholder: "••••••••" %>
          </div>
          <div class="flex items-center gap-2 pt-1">
            <%= f.check_box :remember_me, class: "w-4 h-4 rounded border-white/20 bg-white/5 text-field accent-field" if devise_mapping.rememberable? %>
            <label class="text-sm text-white/50">Recordarme</label>
          </div>
        </div>

        <%= f.button :submit, "Iniciar sesión",
            class: "w-full mt-6 bg-field hover:bg-field-dark text-white font-semibold py-3 px-4 rounded-xl transition-colors" %>
      <% end %>

      <div class="mt-6 pt-6 border-t border-white/10 text-center space-y-2">
<%= link_to "Crear cuenta nueva", new_user_registration_path, class: "block text-sm text-field-light hover:text-field font-medium transition-colors" %>
      </div>
    </div>
  </div>
</div>
