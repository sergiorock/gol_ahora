<div class="row justify-content-center mt-5">
  <div class="col-md-5">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <h2 class="card-title text-center mb-1">⚽ Gol Ahora</h2>
        <p class="text-center text-muted mb-4">Iniciá sesión para continuar</p>

        <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
          <%= f.input :email, label: "Email", autofocus: true, input_html: { autocomplete: "email" } %>
          <%= f.input :password, label: "Contraseña", input_html: { autocomplete: "current-password" } %>
          <%= f.input :remember_me, as: :boolean, label: "Recordarme" if devise_mapping.rememberable? %>
          <%= f.button :submit, "Iniciar sesión", class: "btn btn-success w-100 mt-2" %>
        <% end %>

        <div class="text-center mt-3 text-muted small">
          <%= render "devise/shared/links" %>
        </div>
      </div>
    </div>
  </div>
</div>
