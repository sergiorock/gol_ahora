<div class="min-h-screen flex items-center justify-center px-4 pt-20 pb-12">
  <div class="w-full max-w-2xl">
    <div class="text-center mb-8">
      <h1 class="font-display text-5xl text-white mb-2">CREAR CUENTA</h1>
      <p class="text-white/50">Unite al complejo El Buen Deporte</p>
    </div>

    <div class="bg-white/5 border border-white/10 rounded-2xl p-8">
      <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <%= f.error_notification message: f.object.errors.full_messages.first, class: "text-red-400 text-sm mb-4 bg-red-400/10 border border-red-400/20 rounded-xl px-4 py-3" %>

        <div class="mb-8">
          <h3 class="text-white/50 text-xs font-semibold tracking-widest uppercase mb-4">Datos de acceso</h3>
          <div class="grid sm:grid-cols-2 gap-4">
            <div class="sm:col-span-2">
              <label class="block text-sm font-medium text-white/70 mb-1.5">Email</label>
              <%= f.input_field :email, autofocus: true, autocomplete: "email",
                  class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors",
                  placeholder: "tu@email.com" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-white/70 mb-1.5">Contraseña</label>
              <%= f.input_field :password, autocomplete: "new-password",
                  class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors",
                  placeholder: "••••••••",
                  hint: ("Mínimo #{@minimum_password_length} caracteres" if @minimum_password_length) %>
            </div>
            <div>
              <label class="block text-sm font-medium text-white/70 mb-1.5">Confirmar contraseña</label>
              <%= f.input_field :password_confirmation, autocomplete: "new-password",
                  class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors",
                  placeholder: "••••••••" %>
            </div>
          </div>
        </div>

        <div>
          <h3 class="text-white/50 text-xs font-semibold tracking-widest uppercase mb-4">Datos personales</h3>
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-white/70 mb-1.5">Nombres</label>
              <%= f.input_field :first_name,
                  class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors",
                  placeholder: "Juan" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-white/70 mb-1.5">Apellido</label>
              <%= f.input_field :last_name,
                  class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors",
                  placeholder: "Pérez" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-white/70 mb-1.5">DNI</label>
              <%= f.input_field :dni,
                  class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors",
                  placeholder: "12345678" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-white/70 mb-1.5">Teléfono</label>
              <%= f.input_field :phone,
                  class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors",
                  placeholder: "1112345678" %>
            </div>
            <div class="sm:col-span-2">
              <label class="block text-sm font-medium text-white/70 mb-1.5">Domicilio</label>
              <%= f.input_field :address,
                  class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors",
                  placeholder: "Av. Siempreviva 742" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-white/70 mb-1.5">Ciudad</label>
              <%= f.input_field :city,
                  class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors",
                  placeholder: "Buenos Aires" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-white/70 mb-1.5">País</label>
              <%= f.country_select :country,
                  { priority_countries: %w[AR UY CL BR PY BO], selected: resource.country.presence || "AR", include_blank: "Seleccioná un país" },
                  { class: "w-full bg-gray-900 border border-white/20 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors cursor-pointer" } %>
            </div>
          </div>
        </div>

        <%= f.button :submit, "Crear cuenta",
            class: "w-full mt-8 bg-field hover:bg-field-dark text-white font-semibold py-3 px-4 rounded-xl transition-colors" %>
      <% end %>

      <div class="mt-6 pt-6 border-t border-white/10 text-center">
        <%= link_to "Ya tengo cuenta", new_user_session_path, class: "text-sm text-field-light hover:text-field font-medium transition-colors" %>
      </div>
    </div>
  </div>
</div>
