<div class="row justify-content-center my-4">
  <div class="col-md-8">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <h2 class="card-title text-center mb-1">⚽ Gol Ahora</h2>
        <p class="text-center text-muted mb-4">Creá tu cuenta</p>

        <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
          <%= f.error_notification %>

          <h5 class="mb-3 text-muted">Datos de acceso</h5>
          <div class="row g-3 mb-4">
            <div class="col-md-12">
              <%= f.input :email, label: "Email", autofocus: true, input_html: { autocomplete: "email" } %>
            </div>
            <div class="col-md-6">
              <%= f.input :password, label: "Contraseña",
                          hint: ("Mínimo #{@minimum_password_length} caracteres" if @minimum_password_length),
                          input_html: { autocomplete: "new-password" } %>
            </div>
            <div class="col-md-6">
              <%= f.input :password_confirmation, label: "Confirmar contraseña",
                          input_html: { autocomplete: "new-password" } %>
            </div>
          </div>

          <h5 class="mb-3 text-muted">Datos personales</h5>
          <div class="row g-3">
            <div class="col-md-6">
              <%= f.input :first_name, label: "Nombres" %>
            </div>
            <div class="col-md-6">
              <%= f.input :last_name, label: "Apellido" %>
            </div>
            <div class="col-md-4">
              <%= f.input :dni, label: "DNI" %>
            </div>
            <div class="col-md-4">
              <%= f.input :phone, label: "Teléfono" %>
            </div>
            <div class="col-md-4">
              <%= f.input :age, label: "Edad" %>
            </div>
            <div class="col-md-12">
              <%= f.input :address, label: "Domicilio" %>
            </div>
            <div class="col-md-4">
              <%= f.input :postal_code, label: "Código postal" %>
            </div>
            <div class="col-md-4">
              <%= f.input :city, label: "Ciudad" %>
            </div>
            <div class="col-md-4">
              <%= f.input :country, label: "País" %>
            </div>
          </div>

          <%= f.button :submit, "Registrarse", class: "btn btn-success w-100 mt-4" %>
        <% end %>

        <div class="text-center mt-3 text-muted small">
          <%= render "devise/shared/links" %>
        </div>
      </div>
    </div>
  </div>
</div>
