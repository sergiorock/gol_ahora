<div class="min-h-screen flex items-center justify-center px-4 pt-20 pb-12">
  <div class="w-full max-w-2xl">
    <div class="text-center mb-8">
      <h1 class="font-display text-5xl text-white mb-2">CREAR CUENTA</h1>
      <p class="text-white/50">Unite al complejo El Buen Deporte</p>
    </div>

    <div class="bg-white/5 border border-white/10 rounded-2xl p-8">
      <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <%= f.error_notification message: f.object.errors.full_messages.first, class: "text-red-400 text-sm mb-4 bg-red-400/10 border border-red-400/20 rounded-xl px-4 py-3" %>

        <div class="mb-8">
          <h3 class="text-white/50 text-xs font-semibold tracking-widest uppercase mb-4">Datos de acceso</h3>
          <div class="grid sm:grid-cols-2 gap-4">
            <div class="sm:col-span-2">
              <label class="block text-sm font-medium text-white/70 mb-1.5">Email</label>
              <%= f.input_field :email, autofocus: true, autocomplete: "email",
                  class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors",
                  placeholder: "tu@email.com" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-white/70 mb-1.5">Contraseña</label>
              <div class="relative">
                <%= f.input_field :password, autocomplete: "new-password",
                    id: "user_password",
                    class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 pr-12 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors",
                    placeholder: "••••••••" %>
                <button type="button" onclick="togglePassword('user_password', this)"
                    class="absolute right-3 top-1/2 -translate-y-1/2 text-white/30 hover:text-white/70 transition-colors p-1">
                  <svg class="eye-off w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
                  <svg class="eye-on w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                </button>
              </div>
              <% if @minimum_password_length %>
                <p class="text-white/30 text-xs mt-1.5">Mínimo <%= @minimum_password_length %> caracteres</p>
              <% end %>
            </div>
            <div>
              <label class="block text-sm font-medium text-white/70 mb-1.5">Confirmar contraseña</label>
              <div class="relative">
                <%= f.input_field :password_confirmation, autocomplete: "new-password",
                    id: "user_password_confirmation",
                    class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 pr-12 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors",
                    placeholder: "••••••••" %>
                <button type="button" onclick="togglePassword('user_password_confirmation', this)"
                    class="absolute right-3 top-1/2 -translate-y-1/2 text-white/30 hover:text-white/70 transition-colors p-1">
                  <svg class="eye-off w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
                  <svg class="eye-on w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                </button>
              </div>
              <p id="pw-mismatch" class="text-red-400 text-xs mt-1.5 hidden">Las contraseñas no coinciden</p>
            </div>
          </div>
        </div>

        <div>
          <h3 class="text-white/50 text-xs font-semibold tracking-widest uppercase mb-4">Datos personales</h3>
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-white/70 mb-1.5">Nombres</label>
              <%= f.input_field :first_name,
                  class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors",
                  placeholder: "Juan" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-white/70 mb-1.5">Apellido</label>
              <%= f.input_field :last_name,
                  class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors",
                  placeholder: "Pérez" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-white/70 mb-1.5">DNI</label>
              <%= f.input_field :dni,
                  class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors",
                  placeholder: "12345678" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-white/70 mb-1.5">Fecha de nacimiento</label>
              <input type="date" name="user[birth_date]" id="user_birth_date"
                     max="<%= Date.today.strftime('%Y-%m-%d') %>"
                     value="<%= resource.birth_date&.strftime('%Y-%m-%d') %>"
                     class="w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors">
            </div>
            <div>
              <label class="block text-sm font-medium text-white/70 mb-1.5">Teléfono</label>
              <%= f.input_field :phone,
                  class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors",
                  placeholder: "1112345678" %>
            </div>
            <div class="sm:col-span-2">
              <label class="block text-sm font-medium text-white/70 mb-1.5">Domicilio</label>
              <%= f.input_field :address,
                  class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors",
                  placeholder: "Av. Siempreviva 742" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-white/70 mb-1.5">País</label>
              <%= f.country_select :country,
                  { priority_countries: %w[AR UY CL BR PY BO], selected: resource.country.presence || "AR", include_blank: "Seleccioná un país" },
                  { class: "country-tomselect", data: { placeholder: "Seleccioná un país" } } %>
            </div>
            <div>
              <label class="block text-sm font-medium text-white/70 mb-1.5">Provincia / Estado</label>
              <div id="province-select-wrap">
                <%= f.select :province,
                    options_for_select(User::PROVINCIAS, resource.province.presence || "Buenos Aires"),
                    { include_blank: "Seleccioná una provincia" },
                    { class: "ts-dark", data: { placeholder: "Seleccioná una provincia" } } %>
              </div>
              <div id="province-text-wrap" class="hidden">
                <%= f.input_field :province,
                    class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors",
                    placeholder: "Provincia / Estado",
                    id: "province-text-input",
                    disabled: true %>
              </div>
            </div>
            <div class="sm:col-span-2">
              <label class="block text-sm font-medium text-white/70 mb-1.5">Ciudad</label>
              <%= f.input_field :city,
                  class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors",
                  placeholder: "Buenos Aires" %>
            </div>
            <script>
              document.addEventListener("DOMContentLoaded", function() {
                function toggleProvince() {
                  var country = document.querySelector("select[name='user[country]']");
                  if (!country) return;
                  var isAR = country.value === "AR";
                  document.getElementById("province-select-wrap").classList.toggle("hidden", !isAR);
                  document.getElementById("province-text-wrap").classList.toggle("hidden", isAR);
                  document.getElementById("province-text-input").disabled = isAR;
                  if (!isAR) document.querySelector("select[name='user[province]']").value = "";
                }
                var countryEl = document.querySelector("select[name='user[country]']");
                if (countryEl) { countryEl.addEventListener("change", toggleProvince); toggleProvince(); }
              });
            </script>
          </div>
        </div>

        <%= f.button :submit, "Crear cuenta",
            id: "btn-submit",
            class: "w-full mt-8 bg-field hover:bg-field-dark text-white font-semibold py-3 px-4 rounded-xl transition-colors" %>
      <% end %>

      <div class="mt-6 pt-6 border-t border-white/10 text-center">
        <%= link_to "Ya tengo cuenta", new_user_session_path, class: "text-sm text-field-light hover:text-field font-medium transition-colors" %>
      </div>
    </div>
  </div>
</div>

<script>
  function togglePassword(fieldId, btn) {
    const field = document.getElementById(fieldId);
    const isHidden = field.type === 'password';
    field.type = isHidden ? 'text' : 'password';
    btn.querySelector('.eye-off').classList.toggle('hidden', isHidden);
    btn.querySelector('.eye-on').classList.toggle('hidden', !isHidden);
  }

  const pw  = document.getElementById('user_password');
  const pwc = document.getElementById('user_password_confirmation');
  const msg = document.getElementById('pw-mismatch');
  const btn = document.getElementById('btn-submit');

  function checkPasswords() {
    const mismatch = pwc.value.length > 0 && pw.value !== pwc.value;
    msg.classList.toggle('hidden', !mismatch);
    pwc.classList.toggle('border-red-500', mismatch);
    pwc.classList.toggle('border-white/20', !mismatch);
  }

  pw.addEventListener('input', checkPasswords);
  pwc.addEventListener('input', checkPasswords);

  pwc.closest('form').addEventListener('submit', function(e) {
    if (pw.value !== pwc.value) {
      e.preventDefault();
      msg.classList.remove('hidden');
      pwc.focus();
    }
  });
</script>
