<% content_for :title, "#{@entrenamiento.nombre} — Gol Ahora" %>

<div class="max-w-4xl mx-auto pt-24 pb-16 px-4">

  <div class="mb-8">
    <%= link_to entrenamientos_path, class: "text-white/40 hover:text-white text-sm flex items-center gap-1 mb-6 transition-colors" do %>
      ← Volver a entrenamientos
    <% end %>
    <div class="flex flex-wrap items-center gap-3 mb-4">
      <% if @entrenamiento.full? %>
        <span class="text-xs px-2.5 py-1 rounded-full bg-red-500/20 text-red-400 font-medium">Sin cupo</span>
      <% else %>
        <span class="text-xs px-2.5 py-1 rounded-full bg-green-500/20 text-green-400 font-medium">
          <%= @entrenamiento.spots_available %> lugar<%= @entrenamiento.spots_available == 1 ? "" : "es" %> disponibles
        </span>
      <% end %>
    </div>
    <h1 class="font-display text-6xl sm:text-7xl text-white leading-none mb-2">
      <%= @entrenamiento.nombre.upcase %>
    </h1>
    <p class="text-white/50 flex items-center gap-2">
      Entrenador: <%= @entrenamiento.personal_deportivo.full_name %>
      <% if @entrenamiento.personal_deportivo.certificacion_archivo.attached? %>
        <span class="text-xs bg-green-500/20 text-green-400 px-2 py-0.5 rounded-full font-medium">Certificado</span>
      <% end %>
    </p>
  </div>

  <div class="grid md:grid-cols-3 gap-4 mb-8">
    <div class="bg-white/5 border border-white/10 rounded-xl p-4 text-center">
      <div class="text-white/40 text-xs uppercase tracking-widest mb-1">Horario</div>
      <div class="text-white font-medium text-sm"><%= @entrenamiento.schedule_label %></div>
    </div>
    <div class="bg-white/5 border border-white/10 rounded-xl p-4 text-center">
      <div class="text-white/40 text-xs uppercase tracking-widest mb-1">Duración</div>
      <div class="text-white font-medium"><%= @entrenamiento.duration_minutes %> minutos</div>
    </div>
    <div class="bg-white/5 border border-white/10 rounded-xl p-4 text-center">
      <div class="text-white/40 text-xs uppercase tracking-widest mb-1">Cupo</div>
      <div class="text-white font-medium"><%= @entrenamiento.spots_taken %> / <%= @entrenamiento.max_students %></div>
    </div>
  </div>

  <% if @entrenamiento.descripcion.present? %>
    <div class="bg-white/5 border border-white/10 rounded-xl p-6 mb-8">
      <h2 class="text-white/60 text-xs font-semibold tracking-widest uppercase mb-3">Descripción</h2>
      <p class="text-white/70 leading-relaxed"><%= @entrenamiento.descripcion %></p>
    </div>
  <% end %>

  <div class="flex gap-3">
    <% if user_signed_in? %>
      <% if @my_asistencia %>
        <%= button_to entrenamiento_asistencia_path(@entrenamiento, @my_asistencia),
            method: :delete,
            class: "bg-red-500/20 text-red-400 hover:bg-red-500/30 font-semibold px-6 py-3 rounded-xl transition-all text-sm border border-red-500/30" do %>
          Cancelar inscripción
        <% end %>
      <% elsif !@entrenamiento.full? %>
        <%= button_to entrenamiento_asistencias_path(@entrenamiento),
            method: :post,
            class: "bg-field hover:bg-field-dark text-white font-semibold px-6 py-3 rounded-xl transition-all text-sm" do %>
          Inscribirse a este entrenamiento
        <% end %>
      <% else %>
        <button disabled class="bg-white/10 text-white/30 font-semibold px-6 py-3 rounded-xl text-sm cursor-not-allowed">
          Entrenamiento completo
        </button>
      <% end %>
    <% else %>
      <%= link_to new_user_session_path,
          class: "bg-field hover:bg-field-dark text-white font-semibold px-6 py-3 rounded-xl transition-all text-sm" do %>
        Iniciar sesión para inscribirse
      <% end %>
    <% end %>
    <%= link_to "Ver todos los entrenamientos", entrenamientos_path, class: "text-white/50 hover:text-white text-sm px-4 py-3 transition-colors" %>
  </div>

</div>
