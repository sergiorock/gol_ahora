<% content_for :title, "Pagar seña — Gol Ahora" %>

<div class="max-w-lg mx-auto pt-24 pb-16 px-4">

  <div class="flex items-center gap-4 mb-8">
    <%= link_to @reservation, class: "text-white/40 hover:text-white transition-colors" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    <% end %>
    <div>
      <p class="text-white/40 text-sm">Paso 2 de 2</p>
      <h1 class="font-display text-4xl text-white">PAGAR SEÑA</h1>
    </div>
  </div>

  <%# Resumen %>
  <div class="bg-white/5 border border-white/10 rounded-2xl p-5 mb-6 space-y-3">
    <div class="flex justify-between text-sm">
      <span class="text-white/50">Cancha</span>
      <span class="text-white"><%= @reservation.court.name %></span>
    </div>
    <div class="flex justify-between text-sm">
      <span class="text-white/50">Horario</span>
      <span class="text-white">
        <%= l @reservation.starts_at, format: "%-d %b %Y" %>,
        <%= l @reservation.starts_at, format: "%H:%M" %> – <%= l @reservation.ends_at, format: "%H:%M" %>
      </span>
    </div>
    <div class="flex justify-between text-sm">
      <span class="text-white/50">Total</span>
      <span class="text-white">$<%= number_with_delimiter(@reservation.total_amount) %></span>
    </div>
    <div class="flex justify-between border-t border-white/10 pt-3">
      <span class="text-white/70 font-semibold">Seña a pagar (30%)</span>
      <span class="text-field-light font-display text-2xl">$<%= number_with_delimiter(@reservation.deposit_amount) %></span>
    </div>
  </div>

  <% if @payment.errors.any? %>
    <div class="bg-red-500/10 border border-red-500/30 rounded-xl p-4 mb-6">
      <ul class="text-red-400 text-sm space-y-1">
        <% @payment.errors.full_messages.each do |msg| %>
          <li>• <%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Tarjeta fake %>
  <%= form_with url: confirm_payment_reservation_path(@reservation), method: :post, class: "space-y-5" do |f| %>

    <%# Visualización de tarjeta %>
    <div class="relative h-44 rounded-2xl overflow-hidden bg-gradient-to-br from-slate-700 to-slate-900 border border-white/10 p-6 flex flex-col justify-between select-none" id="card-preview">
      <div class="flex justify-between items-start">
        <div class="space-y-1">
          <div class="w-10 h-7 bg-yellow-400/80 rounded-md"></div>
        </div>
        <span class="text-white/60 text-sm font-semibold tracking-widest">VISA</span>
      </div>
      <div>
        <p class="text-white font-mono text-lg tracking-widest" id="card-number-display">•••• •••• •••• ••••</p>
        <div class="flex justify-between mt-2">
          <p class="text-white/50 text-xs uppercase tracking-widest" id="card-name-display">Nombre titular</p>
          <p class="text-white/50 text-xs font-mono" id="card-expiry-display">MM/AA</p>
        </div>
      </div>
    </div>

    <%# Número de tarjeta %>
    <div>
      <label class="block text-white/60 text-sm mb-2">Número de tarjeta</label>
      <input type="text" id="card-number-input"
             placeholder="1234 5678 9012 3456"
             maxlength="19"
             class="w-full bg-white/5 border border-white/15 rounded-xl px-4 py-3 text-white font-mono tracking-widest placeholder-white/30 focus:outline-none focus:border-field-light">
      <input type="hidden" name="payment[last_four_digits]" id="last-four-hidden">
    </div>

    <%# Nombre %>
    <div>
      <label class="block text-white/60 text-sm mb-2">Nombre del titular</label>
      <input type="text" name="payment[cardholder_name]"
             placeholder="Como figura en la tarjeta"
             id="cardholder-input"
             class="w-full bg-white/5 border border-white/15 rounded-xl px-4 py-3 text-white uppercase placeholder-white/30 focus:outline-none focus:border-field-light">
    </div>

    <%# Vencimiento + CVV %>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-white/60 text-sm mb-2">Vencimiento</label>
        <input type="text" name="payment[expiry_date]"
               placeholder="MM/AA"
               maxlength="5"
               id="expiry-input"
               class="w-full bg-white/5 border border-white/15 rounded-xl px-4 py-3 text-white font-mono placeholder-white/30 focus:outline-none focus:border-field-light">
      </div>
      <div>
        <label class="block text-white/60 text-sm mb-2">CVV</label>
        <input type="password" placeholder="•••" maxlength="4"
               class="w-full bg-white/5 border border-white/15 rounded-xl px-4 py-3 text-white font-mono placeholder-white/30 focus:outline-none focus:border-field-light">
      </div>
    </div>

    <button type="submit" class="w-full bg-field hover:bg-field-dark text-white font-semibold py-4 rounded-xl transition-all flex items-center justify-center gap-2">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
      Pagar $<%= number_with_delimiter(@reservation.deposit_amount) %>
    </button>

    <p class="text-center text-white/30 text-xs">Pago simulado — no se procesa ninguna transacción real</p>
  <% end %>

</div>

<script>
  const numberInput   = document.getElementById('card-number-input');
  const lastFour      = document.getElementById('last-four-hidden');
  const numberDisplay = document.getElementById('card-number-display');
  const nameInput     = document.getElementById('cardholder-input');
  const nameDisplay   = document.getElementById('card-name-display');
  const expiryInput   = document.getElementById('expiry-input');
  const expiryDisplay = document.getElementById('card-expiry-display');

  numberInput.addEventListener('input', function() {
    let v = this.value.replace(/\D/g, '').slice(0, 16);
    this.value = v.replace(/(.{4})/g, '$1 ').trim();
    const digits = v.padEnd(16, '•');
    numberDisplay.textContent = digits.replace(/(.{4})/g, '$1 ').trim();
    lastFour.value = v.slice(-4);
  });

  nameInput.addEventListener('input', function() {
    nameDisplay.textContent = this.value.toUpperCase() || 'Nombre titular';
  });

  expiryInput.addEventListener('input', function() {
    let v = this.value.replace(/\D/g, '').slice(0, 4);
    if (v.length >= 3) v = v.slice(0,2) + '/' + v.slice(2);
    this.value = v;
    expiryDisplay.textContent = v || 'MM/AA';
  });
</script>
