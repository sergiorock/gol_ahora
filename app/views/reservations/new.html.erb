<% content_for :title, "Nueva reserva — Gol Ahora" %>

<div class="max-w-2xl mx-auto pt-24 pb-16 px-4">

  <div class="flex items-center gap-4 mb-8">
    <%= link_to (@court ? court_path(@court) : courts_path), class: "text-white/40 hover:text-white transition-colors" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    <% end %>
    <div>
      <p class="text-white/40 text-sm">Nueva reserva</p>
      <h1 class="font-display text-4xl text-white">RESERVAR CANCHA</h1>
    </div>
  </div>

  <% errors = (@reservation.errors.full_messages + @payment.errors.full_messages).uniq %>
  <% if errors.any? %>
    <div class="bg-red-500/10 border border-red-500/30 rounded-xl p-4 mb-6">
      <ul class="text-red-400 text-sm space-y-1">
        <% errors.each do |msg| %>
          <li>• <%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Precios por cancha para el cálculo JS %>
  <% court_prices = Court.includes(:court_type).available.each_with_object({}) { |c, h| h[c.id.to_s] = c.court_type.price_per_hour.to_f } %>

  <%= form_with url: reservations_path, method: :post,
        id: "reservation-form",
        data: { prices: court_prices.to_json, fixed_court: @court&.id },
        class: "space-y-6" do |f| %>

    <%# ── Sección 1: Horario ──────────────────────────────── %>
    <div class="bg-white/5 border border-white/10 rounded-2xl p-6 space-y-5">
      <h2 class="text-white/50 text-xs font-semibold tracking-widest uppercase">1 · Elegí el horario</h2>

      <%# Cancha %>
      <% if @court %>
        <input type="hidden" name="reservation[court_id]" value="<%= @court.id %>">
        <div class="flex items-center gap-4">
          <div class="w-14 h-14 rounded-xl overflow-hidden flex-shrink-0">
            <%= court_surface_svg(@court.court_type, css_class: "w-full h-full") %>
          </div>
          <div>
            <p class="text-white font-semibold"><%= @court.name %></p>
            <p class="text-white/50 text-sm"><%= @court.court_type.name %> · <%= CourtType::SURFACE_LABELS[@court.court_type.surface] %></p>
            <p class="text-field-light text-sm">$<%= number_with_delimiter(@court.court_type.price_per_hour.to_i) %>/hora · máx. <%= @court.court_type.duration_label %></p>
          </div>
        </div>
      <% else %>
        <div>
          <label class="block text-white/60 text-sm mb-2">Cancha</label>
          <select name="reservation[court_id]" id="court-select" class="ts-dark" data-placeholder="Seleccioná una cancha">
            <option value=""></option>
            <% Court.includes(:court_type).available.each do |c| %>
              <option value="<%= c.id %>"><%= c.name %> — <%= c.court_type.name %></option>
            <% end %>
          </select>
        </div>
      <% end %>

      <%# Fecha %>
      <div>
        <label class="block text-white/60 text-sm mb-2">Fecha</label>
        <input type="date"
               name="reservation[date]"
               value="<%= params.dig(:reservation, :date) || Date.tomorrow.strftime('%Y-%m-%d') %>"
               min="<%= Date.today.strftime('%Y-%m-%d') %>"
               max="<%= 30.days.from_now.strftime('%Y-%m-%d') %>"
               class="w-full bg-white/5 border border-white/15 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-field-light">
      </div>

      <%# Hora inicio / fin %>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-white/60 text-sm mb-2">Hora de inicio</label>
          <select name="reservation[start_time]" id="start-time-select" class="ts-dark">
            <% (8..22).each do |h| %>
              <% ["00", "30"].each do |m| %>
                <% val = "#{h.to_s.rjust(2,'0')}:#{m}" %>
                <option value="<%= val %>" <%= "selected" if params.dig(:reservation, :start_time) == val %>><%= val %></option>
              <% end %>
            <% end %>
          </select>
        </div>
        <div>
          <label class="block text-white/60 text-sm mb-2">Hora de fin</label>
          <select name="reservation[end_time]" id="end-time-select" class="ts-dark">
            <% (8..23).each do |h| %>
              <% ["00", "30"].each do |m| %>
                <% val = "#{h.to_s.rjust(2,'0')}:#{m}" %>
                <option value="<%= val %>" <%= "selected" if (params.dig(:reservation, :end_time) || "09:00") == val %>><%= val %></option>
              <% end %>
            <% end %>
          </select>
        </div>
      </div>

      <%# Notas %>
      <div>
        <label class="block text-white/60 text-sm mb-2">Notas (opcional)</label>
        <textarea name="reservation[notes]" rows="2"
                  placeholder="Indicaciones especiales, cantidad de jugadores, etc."
                  class="w-full bg-white/5 border border-white/15 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light resize-none"><%= params.dig(:reservation, :notes) %></textarea>
      </div>
    </div>

    <%# ── Resumen de costos en tiempo real ───────────────── %>
    <div id="price-summary" class="border border-field/40 bg-field/5 rounded-2xl p-5 space-y-3 hidden">
      <h3 class="text-white/50 text-xs font-semibold tracking-widest uppercase">Resumen</h3>
      <div class="flex justify-between text-sm">
        <span class="text-white/60">Duración</span>
        <span class="text-white" id="summary-duration">—</span>
      </div>
      <div class="flex justify-between text-sm">
        <span class="text-white/60">Precio/hora</span>
        <span class="text-white" id="summary-rate">—</span>
      </div>
      <div class="flex justify-between border-t border-white/10 pt-3">
        <span class="text-white/70 font-semibold">Total</span>
        <span class="text-white font-semibold text-lg" id="summary-total">—</span>
      </div>
      <div class="flex justify-between">
        <span class="text-white/60 text-sm">Seña a pagar (30%)</span>
        <span class="text-field-light font-display text-2xl" id="summary-deposit">—</span>
      </div>
    </div>

    <%# ── Sección 2: Pago de la seña ─────────────────────── %>
    <div class="bg-white/5 border border-white/10 rounded-2xl p-6 space-y-5">
      <h2 class="text-white/50 text-xs font-semibold tracking-widest uppercase">2 · Pagá la seña (30%)</h2>

      <%# Preview de tarjeta %>
      <div class="relative h-40 rounded-2xl overflow-hidden bg-gradient-to-br from-slate-700 to-slate-900 border border-white/10 p-5 flex flex-col justify-between select-none">
        <div class="flex justify-between items-start">
          <div class="w-9 h-6 bg-yellow-400/80 rounded"></div>
          <span class="text-white/60 text-sm font-semibold tracking-widest">VISA</span>
        </div>
        <div>
          <p class="text-white font-mono tracking-widest" id="card-number-display">•••• •••• •••• ••••</p>
          <div class="flex justify-between mt-1">
            <p class="text-white/50 text-xs uppercase tracking-widest" id="card-name-display">Nombre titular</p>
            <p class="text-white/50 text-xs font-mono" id="card-expiry-display">MM/AA</p>
          </div>
        </div>
      </div>

      <%# Número de tarjeta %>
      <div>
        <label class="block text-white/60 text-sm mb-2">Número de tarjeta</label>
        <input type="text" id="card-number-input"
               placeholder="1234 5678 9012 3456" maxlength="19"
               class="w-full bg-white/5 border border-white/15 rounded-xl px-4 py-3 text-white font-mono tracking-widest placeholder-white/30 focus:outline-none focus:border-field-light">
        <input type="hidden" name="payment[last_four_digits]" id="last-four-hidden">
      </div>

      <%# Nombre %>
      <div>
        <label class="block text-white/60 text-sm mb-2">Nombre del titular</label>
        <input type="text" name="payment[cardholder_name]"
               placeholder="Como figura en la tarjeta" id="cardholder-input"
               value="<%= params.dig(:payment, :cardholder_name) %>"
               class="w-full bg-white/5 border border-white/15 rounded-xl px-4 py-3 text-white uppercase placeholder-white/30 focus:outline-none focus:border-field-light">
      </div>

      <%# Vencimiento + CVV %>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-white/60 text-sm mb-2">Vencimiento</label>
          <input type="text" name="payment[expiry_date]"
                 placeholder="MM/AA" maxlength="5" id="expiry-input"
                 value="<%= params.dig(:payment, :expiry_date) %>"
                 class="w-full bg-white/5 border border-white/15 rounded-xl px-4 py-3 text-white font-mono placeholder-white/30 focus:outline-none focus:border-field-light">
        </div>
        <div>
          <label class="block text-white/60 text-sm mb-2">CVV</label>
          <input type="password" placeholder="•••" maxlength="4"
                 class="w-full bg-white/5 border border-white/15 rounded-xl px-4 py-3 text-white font-mono placeholder-white/30 focus:outline-none focus:border-field-light">
        </div>
      </div>

      <p class="text-white/30 text-xs text-center">Pago simulado — no se procesa ninguna transacción real</p>
    </div>

    <button type="submit" class="w-full bg-field hover:bg-field-dark text-white font-semibold py-4 rounded-xl transition-all flex items-center justify-center gap-2">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
      <span id="submit-label">Confirmar reserva y pagar seña</span>
    </button>
  <% end %>

</div>

<script>
  (() => {
    const form       = document.getElementById('reservation-form');
    const prices     = JSON.parse(form.dataset.prices || '{}');
    const fixedCourt = form.dataset.fixedCourt;
    const startSel   = document.getElementById('start-time-select');
    const endSel     = document.getElementById('end-time-select');
    const courtSel   = document.getElementById('court-select');
    const summary    = document.getElementById('price-summary');
    const submitLabel = document.getElementById('submit-label');

    const fmtARS = n => '$' + Math.round(n).toLocaleString('es-AR');

    function timeToMin(t) { const [h,m] = t.split(':').map(Number); return h*60+m; }

    function recalculate() {
      if (!userTouched) { summary.classList.add('hidden'); return; }

      const courtId    = fixedCourt || (courtSel ? courtSel.value : null);
      const priceHour  = courtId ? prices[courtId] : null;
      const startVal   = startSel ? startSel.value : null;
      const endVal     = endSel   ? endSel.value   : null;

      if (!priceHour || !startVal || !endVal) { summary.classList.add('hidden'); return; }

      const diff = timeToMin(endVal) - timeToMin(startVal);
      if (diff <= 0) { summary.classList.add('hidden'); return; }

      const total   = priceHour * (diff / 60);
      const deposit = total * 0.30;
      const durLabel = diff % 60 === 0 ? `${diff/60}h` : `${Math.floor(diff/60)}h ${diff%60}min`;

      document.getElementById('summary-duration').textContent = durLabel;
      document.getElementById('summary-rate').textContent     = fmtARS(priceHour) + '/hora';
      document.getElementById('summary-total').textContent    = fmtARS(total);
      document.getElementById('summary-deposit').textContent  = fmtARS(deposit);
      submitLabel.textContent = `Confirmar y pagar seña ${fmtARS(deposit)}`;
      summary.classList.remove('hidden');
    }

    // Disponibilidad — filtra opciones en Tom Select
    const dateInput = form.querySelector('input[name="reservation[date]"]');
    const submitBtn = form.querySelector('button[type="submit"]');
    let unavailable = [], maxDuration = 9999, userTouched = false;

    // Opciones originales (todas las medias horas) — capturadas antes de que Tom Select las toque
    const allStart = Array.from(startSel?.options || []).map(o => o.value).filter(Boolean);
    const allEnd   = Array.from(endSel?.options   || []).map(o => o.value).filter(Boolean);

    function setOptions(sel, opts) {
      if (!sel) return;
      const ts   = sel.tomselect;
      const cur  = ts ? ts.getValue() : sel.value;
      const next = opts.includes(cur) ? cur : (opts[0] || '');

      if (ts) {
        // Tom Select ya está listo — usar su API directamente
        ts.clear(true);
        ts.clearOptions();
        opts.forEach(v => ts.addOption({ value: v, text: v }));
        ts.setValue(next, true);
        ts.refreshOptions(false);
      } else {
        // Tom Select aún no inicializó — modificar el native select (lo leerá al init)
        sel.innerHTML = opts.map(v => `<option value="${v}"${v === next ? ' selected' : ''}>${v}</option>`).join('');
      }
    }

    function updateStartOptions() {
      const valid = allStart.filter(v => {
        const min = timeToMin(v);
        return !unavailable.some(({ from, to }) => min >= timeToMin(from) && min < timeToMin(to));
      });
      setOptions(startSel, valid);
    }

    function updateEndOptions() {
      const startMin  = timeToMin(startSel?.value || '08:00');
      const nextBlock = unavailable.map(b => timeToMin(b.from)).filter(m => m > startMin).sort((a,b)=>a-b)[0] ?? 9999;
      const valid = allEnd.filter(v => {
        const min = timeToMin(v), diff = min - startMin;
        return diff > 0 && diff <= maxDuration && min <= nextBlock;
      });
      setOptions(endSel, valid);
    }

    function autoCompleteEnd() {
      const startMin  = timeToMin(startSel?.value || '08:00');
      const targetEnd = String(Math.floor((startMin+60)/60)).padStart(2,'0') + ':' + String((startMin+60)%60).padStart(2,'0');
      const endOpts   = Array.from(endSel?.options || []).map(o => o.value);
      if (endOpts.includes(targetEnd)) {
        endSel.value = targetEnd;
        endSel.tomselect?.setValue(targetEnd, true);
      }
    }

    async function fetchAvailability() {
      const courtId = fixedCourt || courtSel?.value;
      if (!courtId || !dateInput?.value) return;
      try {
        const res  = await fetch(`/courts/${courtId}/availability?date=${dateInput.value}`);
        const data = await res.json();
        unavailable = data.unavailable || [];
        maxDuration = data.max_duration_minutes || 9999;
      } catch(e) {}
      updateStartOptions();
      updateEndOptions();
      autoCompleteEnd();
      // Retorna Promise implícitamente por ser async
    }

    dateInput?.addEventListener('change', fetchAvailability);
    if (courtSel) courtSel.addEventListener('change', fetchAvailability);

    startSel?.addEventListener('change', () => {
      userTouched = true;
      updateEndOptions();
      autoCompleteEnd();
      recalculate();
    });
    endSel?.addEventListener('change', () => {
      userTouched = true;
      recalculate();
    });
    if (courtSel) courtSel.addEventListener('change', () => { userTouched = false; recalculate(); });

    // Corre después del DOMContentLoaded del layout (donde se inicializa Tom Select)
    document.addEventListener('DOMContentLoaded', () => {
      if ((fixedCourt || courtSel?.value) && dateInput?.value) {
        fetchAvailability().then(() => { userTouched = true; recalculate(); });
      }
    });

    // Preview de tarjeta
    const numInput  = document.getElementById('card-number-input');
    const lastFour  = document.getElementById('last-four-hidden');
    const numDisp   = document.getElementById('card-number-display');
    const nameInput = document.getElementById('cardholder-input');
    const nameDisp  = document.getElementById('card-name-display');
    const expInput  = document.getElementById('expiry-input');
    const expDisp   = document.getElementById('card-expiry-display');

    numInput.addEventListener('input', function() {
      let v = this.value.replace(/\D/g,'').slice(0,16);
      this.value = v.replace(/(.{4})/g,'$1 ').trim();
      numDisp.textContent = v.padEnd(16,'•').replace(/(.{4})/g,'$1 ').trim();
      lastFour.value = v.slice(-4);
    });
    nameInput.addEventListener('input', function() {
      nameDisp.textContent = this.value.toUpperCase() || 'Nombre titular';
    });
    expInput.addEventListener('input', function() {
      let v = this.value.replace(/\D/g,'').slice(0,4);
      if (v.length >= 3) v = v.slice(0,2)+'/'+v.slice(2);
      this.value = v;
      expDisp.textContent = v || 'MM/AA';
    });
  })();
</script>
