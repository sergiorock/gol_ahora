<% content_for :title, "Mis reservas — Gol Ahora" %>

<div class="max-w-4xl mx-auto pt-24 pb-16 px-4">

  <div class="flex items-start justify-between mb-10">
    <div>
      <p class="text-field-light text-sm font-medium tracking-widest uppercase mb-2">Mi cuenta</p>
      <h1 class="font-display text-5xl text-white">MIS RESERVAS</h1>
    </div>
    <%= link_to courts_path, class: "mt-2 flex items-center gap-2 text-field-light hover:text-white transition-colors text-sm" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Nueva reserva
    <% end %>
  </div>

  <% if @reservations.empty? %>
    <div class="text-center py-20 text-white/30">
      <svg class="w-16 h-16 mx-auto mb-4 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      <p class="text-lg font-medium">Todavía no tenés reservas</p>
      <p class="text-sm mt-1">
        <%= link_to "Ver canchas disponibles", courts_path, class: "text-field-light hover:underline" %>
      </p>
    </div>
  <% else %>
    <div class="space-y-4">
      <% @reservations.each do |r| %>
        <%= link_to reservation_path(r), class: "block bg-white/5 hover:bg-white/8 border border-white/10 hover:border-white/20 rounded-2xl p-5 transition-all" do %>
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl overflow-hidden flex-shrink-0">
              <%= court_surface_svg(r.court.court_type, css_class: "w-full h-full") %>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-white font-semibold"><%= r.court.name %></span>
                <span class="text-white/40 text-xs">·</span>
                <span class="text-white/50 text-sm"><%= r.court.court_type.name %></span>
              </div>
              <p class="text-white/50 text-sm">
                <%= l r.starts_at, format: "%-d de %B %Y" %> · <%= l r.starts_at, format: "%H:%M" %> – <%= l r.ends_at, format: "%H:%M" %>
              </p>
            </div>
            <div class="text-right flex-shrink-0">
              <%= reservation_status_badge(r.status) %>
              <p class="text-white/50 text-xs mt-1">$<%= number_with_delimiter(r.total_amount) %></p>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>

</div>
