<% content_for :title, "Reserva #<%= @reservation.id %> — Gol Ahora" %>

<div class="max-w-2xl mx-auto pt-24 pb-16 px-4">

  <div class="flex items-center gap-4 mb-8">
    <%= link_to reservations_path, class: "text-white/40 hover:text-white transition-colors" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    <% end %>
    <div>
      <p class="text-white/40 text-sm">Reserva #<%= @reservation.id %></p>
      <h1 class="font-display text-4xl text-white"><%= @reservation.court.name.upcase %></h1>
    </div>
    <div class="ml-auto">
      <%= reservation_status_badge(@reservation.status) %>
    </div>
  </div>

  <div class="space-y-4">
    <%# Detalle principal %>
    <div class="bg-white/5 border border-white/10 rounded-2xl p-6 space-y-4">
      <div class="grid grid-cols-2 gap-4 text-sm">
        <div>
          <p class="text-white/40 mb-1">Cancha</p>
          <p class="text-white font-medium"><%= @reservation.court.name %></p>
          <p class="text-white/50 text-xs"><%= @reservation.court.court_type.name %> · <%= CourtType::SURFACE_LABELS[@reservation.court.court_type.surface] %></p>
        </div>
        <div>
          <p class="text-white/40 mb-1">Horario</p>
          <p class="text-white font-medium"><%= l @reservation.starts_at, format: "%-d de %B %Y" %></p>
          <p class="text-white/50 text-xs"><%= l @reservation.starts_at, format: "%H:%M" %> – <%= l @reservation.ends_at, format: "%H:%M" %> (<%= @reservation.duration_minutes %> min)</p>
        </div>
        <div>
          <p class="text-white/40 mb-1">Monto total</p>
          <p class="text-white font-medium">$<%= number_with_delimiter(@reservation.total_amount.to_i) %></p>
        </div>
        <div>
          <p class="text-white/40 mb-1">Seña (30%)</p>
          <p class="text-white font-medium">$<%= number_with_delimiter(@reservation.deposit_amount.to_i) %></p>
        </div>
      </div>

      <% if @reservation.notes.present? %>
        <div class="border-t border-white/10 pt-4">
          <p class="text-white/40 text-xs mb-1">Notas</p>
          <p class="text-white/70 text-sm"><%= @reservation.notes %></p>
        </div>
      <% end %>
    </div>

    <%# Estado del pago %>
    <div class="bg-white/5 border border-white/10 rounded-2xl p-6">
      <h3 class="text-white/50 text-xs font-semibold tracking-widest uppercase mb-4">Pagos</h3>
      <% if @reservation.payments.any? %>
        <% @reservation.payments.each do |payment| %>
          <div class="flex items-center justify-between py-2 border-b border-white/5 last:border-0">
            <div>
              <p class="text-white text-sm"><%= payment.payment_type == "deposit" ? "Seña" : "Pago total" %></p>
              <p class="text-white/40 text-xs">•••• <%= payment.last_four_digits %> · <%= payment.cardholder_name %></p>
            </div>
            <div class="text-right">
              <p class="text-white text-sm">$<%= number_with_delimiter(payment.amount.to_i) %></p>
              <span class="text-xs <%= payment.approved? ? 'text-green-400' : 'text-yellow-400' %>">
                <%= payment.approved? ? "Aprobado" : payment.status.humanize %>
              </span>
            </div>
          </div>
        <% end %>
      <% else %>
        <p class="text-white/40 text-sm">Sin pagos registrados.</p>
      <% end %>
    </div>

    <%# Acciones %>
    <% if @reservation.pending? || @reservation.confirmed? %>
      <div class="flex gap-3">
        <%= button_to cancel_reservation_path(@reservation), method: :delete,
              class: "px-6 py-3 border border-red-500/40 hover:border-red-500 text-red-400 hover:text-red-300 rounded-xl transition-all text-sm",
              data: { confirm: "¿Cancelar esta reserva?" } do %>
          Cancelar reserva
        <% end %>
      </div>
    <% end %>
  </div>

</div>
