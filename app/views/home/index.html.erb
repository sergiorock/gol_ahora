<% content_for :title, "Gol Ahora - Reservas de canchas" %>

<% steps = [
  ["01", "Elegí cancha", "Filtrá por formato, superficie y horario libre."],
  ["02", "Reservá el turno", "Bloqueá el horario con seña online y confirmación."],
  ["03", "Armá el equipo", "Compartí la reserva y llegá con el partido listo."],
  ["04", "Jugá", "El complejo valida el turno y cobra el saldo."]
] %>

<% benefits = [
  ["Agenda clara", "Horarios, precios y disponibilidad en una sola pantalla.", "calendar-event"],
  ["Menos cancelaciones", "La seña online deja el turno tomado y reduce ausencias.", "shield-check"],
  ["Competencias", "Ligas, torneos, fixtures y resultados conectados al complejo.", "trophy"],
  ["Formación", "Clases y entrenamientos con asistencia registrada.", "school"],
  ["Autogestión", "Reservas, inscripciones y pagos sin llamadas cruzadas.", "device-mobile-check"],
  ["Panel admin", "El complejo administra canchas, bloqueos, usuarios y reportes.", "layout-dashboard"]
] %>

<section class="relative min-h-[780px] overflow-hidden bg-[#071323] text-white sm:min-h-[860px]">
  <div class="absolute inset-0">
    <%= image_tag "home/hero-video-poster.png", alt: "", class: "absolute inset-0 h-full w-full object-cover object-center opacity-90" %>
    <video id="hero-video" class="absolute inset-0 h-full w-full object-cover object-center opacity-90 motion-reduce:hidden" autoplay muted loop playsinline preload="metadata" poster="<%= asset_path("home/hero-video-poster.png") %>" aria-hidden="true">
      <source src="/videos/home/hero-goal.mp4" type="video/mp4">
    </video>
    <div class="absolute inset-0 bg-gradient-to-r from-[#071323]/90 via-[#071323]/56 to-[#071323]/5"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[#071323]/72 via-transparent to-[#071323]/5"></div>
  </div>

  <div class="relative mx-auto flex min-h-[780px] max-w-7xl items-center px-4 pb-20 pt-32 sm:min-h-[860px] sm:px-6 sm:pb-24 lg:px-8">
    <div class="max-w-3xl">
      <div id="hero-badge" class="mb-6 inline-flex items-center gap-3 border border-white/25 bg-black/20 px-3 py-2 text-xs font-bold uppercase tracking-[0.2em] text-white/85 backdrop-blur">
        <span class="h-2 w-2 bg-field"></span>
        Plataforma de reservas deportivas
      </div>

      <h1 id="hero-title" class="text-5xl font-black leading-[0.95] tracking-normal text-white sm:text-6xl lg:text-7xl">
        Tu cancha, tu equipo, tu horario.
      </h1>

      <p id="hero-sub" class="mt-6 max-w-xl text-base leading-7 text-white/70 sm:text-lg">
        Reservá fútbol 5, 7 y 11 en minutos. Gol Ahora ordena turnos, señas, ligas, torneos y entrenamientos para que el partido no dependa de mensajes sueltos.
      </p>

      <div id="hero-cta" class="mt-8 flex flex-col gap-3 sm:flex-row">
        <%= link_to courts_path, class: "inline-flex items-center justify-center gap-2 bg-field px-6 py-3 text-sm font-black text-zinc-950 transition hover:bg-field-light" do %>
          Reservar una cancha
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        <% end %>
        <%= link_to tournaments_path, class: "inline-flex items-center justify-center border border-white/25 bg-white/10 px-6 py-3 text-sm font-bold text-white transition hover:border-field hover:text-field-light" do %>
          Ver competencias
        <% end %>
      </div>

      <div class="mt-12 grid max-w-2xl gap-px border border-white/18 bg-white/15 shadow-2xl shadow-[#071323]/30 sm:grid-cols-3">
        <div class="bg-[#071323]/45 p-4 backdrop-blur">
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-white/65">Formatos</p>
          <p class="mt-2 text-lg font-black">F5 · F7 · F11</p>
        </div>
        <div class="bg-[#071323]/45 p-4 backdrop-blur">
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-white/65">Reserva</p>
          <p class="mt-2 text-lg font-black">100% web</p>
        </div>
        <div class="bg-[#071323]/45 p-4 backdrop-blur">
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-white/65">Estado</p>
          <p class="mt-2 text-lg font-black">Confirmación online</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="bg-[#071323] text-white">
  <div class="mx-auto grid max-w-7xl grid-cols-2 gap-px px-4 py-8 sm:px-6 lg:grid-cols-4 lg:px-8">
    <% @stats.each do |value, label| %>
      <div class="border-white/10 py-4 text-center lg:border-r last:border-r-0">
        <p class="text-3xl font-black text-white"><%= value.is_a?(Numeric) ? number_with_delimiter(value, delimiter: ".") : value %></p>
        <p class="mt-1 text-xs font-bold uppercase tracking-[0.16em] text-orange-200"><%= label %></p>
      </div>
    <% end %>
  </div>
</section>

<section class="relative overflow-hidden bg-[#f5f2ec] py-24 text-[#071323]">
  <div class="absolute inset-0 opacity-70" style="background-image: linear-gradient(rgba(7,19,35,0.055) 1px, transparent 1px), linear-gradient(90deg, rgba(7,19,35,0.055) 1px, transparent 1px); background-size: 48px 48px;"></div>
  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="inline-flex items-center gap-2 border border-[#071323]/15 bg-white/60 px-3 py-1.5 text-xs font-bold uppercase tracking-[0.2em] text-[#071323]/70">
        <span class="h-2 w-2 bg-field"></span>
        Cómo funciona
      </p>
      <h2 class="mt-5 text-4xl font-black leading-tight sm:text-5xl">
        Mirá turnos libres y cerrá la reserva sin llamar al complejo.
      </h2>
    </div>

    <div id="flow-grid" class="mt-14 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      <% steps.each do |number, title, body| %>
        <div class="flow-card border border-[#071323]/12 bg-white/80 p-6 shadow-sm">
          <p class="inline-flex bg-field px-3 py-2 text-xs font-black text-zinc-950"><%= number %></p>
          <h3 class="mt-8 text-xl font-black"><%= title %></h3>
          <p class="mt-3 text-sm leading-6 text-[#373737]/75"><%= body %></p>
        </div>
      <% end %>
    </div>

    <div class="mt-6 grid gap-px border border-[#071323]/15 bg-[#071323]/15 md:grid-cols-3">
      <div class="bg-[#071323] p-5 text-white">
        <p class="text-xs font-bold uppercase tracking-[0.18em] text-field-light">Disponibilidad</p>
        <p class="mt-2 text-sm leading-6 text-white/70">La cancha publicada muestra horarios disponibles y evita consultas repetidas.</p>
      </div>
      <div class="bg-[#071323] p-5 text-white">
        <p class="text-xs font-bold uppercase tracking-[0.18em] text-field-light">Seña</p>
        <p class="mt-2 text-sm leading-6 text-white/70">El turno queda tomado con pago inicial y el complejo cobra el saldo al llegar.</p>
      </div>
      <div class="bg-[#071323] p-5 text-white">
        <p class="text-xs font-bold uppercase tracking-[0.18em] text-field-light">Confirmación</p>
        <p class="mt-2 text-sm leading-6 text-white/70">Jugador y complejo comparten el mismo estado de la reserva.</p>
      </div>
    </div>
  </div>
</section>

<section id="canchas" class="benefits-field-bg relative overflow-hidden bg-[#faf9f6] py-24 text-[#071323]">
  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.22em] text-field-dark">Beneficios</p>
        <h2 class="mt-4 text-4xl font-black sm:text-5xl">Una app para jugadores y para el complejo.</h2>
      </div>
      <%= link_to "Ver canchas", courts_path, class: "inline-flex w-fit border border-[#071323]/20 px-5 py-3 text-sm font-black text-[#071323] transition hover:border-field hover:text-field-dark" %>
    </div>

    <div id="benefits-grid" class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      <% benefits.each do |title, body, icon| %>
        <div class="benefit-card border border-[#071323]/12 bg-white/90 p-6 shadow-sm">
          <div class="mb-7 grid h-12 w-12 place-items-center border border-field/20 bg-field/10 text-field-dark">
            <i class="ti ti-<%= icon %> text-3xl" aria-hidden="true"></i>
          </div>
          <h3 class="text-lg font-black"><%= title %></h3>
          <p class="mt-3 text-sm leading-6 text-[#373737]/75"><%= body %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<section class="relative min-h-[520px] overflow-hidden bg-[#071323] text-white">
  <%= image_tag "home/training-session-1920.jpg", alt: "", class: "absolute inset-0 h-full w-full object-cover object-center opacity-85" %>
  <div class="absolute inset-0 bg-gradient-to-r from-[#071323]/90 via-[#071323]/54 to-[#071323]/10"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-[#071323] via-transparent to-transparent"></div>

  <div class="relative mx-auto grid min-h-[520px] max-w-7xl items-center gap-10 px-4 py-20 sm:px-6 lg:grid-cols-[0.8fr_1.2fr] lg:px-8">
    <div>
      <p class="inline-flex border border-field/30 bg-field/15 px-3 py-1.5 text-xs font-bold uppercase tracking-[0.18em] text-field-light">Profesores</p>
      <h2 class="mt-5 text-4xl font-black leading-tight sm:text-5xl">Clases y entrenamientos también se reservan desde acá.</h2>
      <p class="mt-5 max-w-xl text-sm leading-7 text-white/60">
        Sumá actividad fuera del alquiler por hora: profesores, cupos, asistencias e inscripciones conectadas al mismo perfil de jugador.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <%= link_to "Ver clases", clases_path, class: "inline-flex justify-center bg-field px-6 py-3 text-sm font-black text-zinc-950 hover:bg-field-light" %>
        <%= link_to "Entrenamientos", entrenamientos_path, class: "inline-flex justify-center border border-white/25 bg-white/10 px-6 py-3 text-sm font-black text-white hover:border-field hover:text-field-light" %>
      </div>
    </div>
  </div>
</section>

<% unless user_signed_in? %>
  <section class="goal-net-bg relative overflow-hidden bg-[#071323] py-24 text-center text-white">
    <div class="relative mx-auto max-w-3xl px-4">
      <p class="inline-flex border border-white/20 bg-white/10 px-3 py-1.5 text-xs font-bold uppercase tracking-[0.2em] text-white/75">Empezá ahora</p>
      <h2 class="mt-5 text-4xl font-black leading-tight sm:text-5xl">Registrate, reservá y armá tu partido.</h2>
      <p class="mx-auto mt-5 max-w-xl text-sm leading-7 text-white/60">Para jugadores y complejos deportivos. Disponible desde la web, sin instalar nada.</p>
      <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
        <%= link_to "Crear cuenta", new_user_registration_path, class: "inline-flex justify-center bg-field px-6 py-3 text-sm font-black text-zinc-950 hover:bg-field-light" %>
        <%= link_to "Iniciar sesión", new_user_session_path, class: "inline-flex justify-center border border-white/20 px-6 py-3 text-sm font-black text-white/85 hover:border-white/40 hover:text-white" %>
      </div>
    </div>
  </section>
<% end %>

<script type="module">
  import { animate, inView, stagger } from 'https://cdn.jsdelivr.net/npm/motion@latest/+esm'

  animate('#hero-badge', { opacity: [0, 1], y: [12, 0] }, { duration: 0.45, delay: 0.05 })
  animate('#hero-title', { opacity: [0, 1], y: [28, 0] }, { duration: 0.65, delay: 0.18, easing: [0.16, 1, 0.3, 1] })
  animate('#hero-sub', { opacity: [0, 1], y: [18, 0] }, { duration: 0.55, delay: 0.32 })
  animate('#hero-cta', { opacity: [0, 1], y: [14, 0] }, { duration: 0.5, delay: 0.45 })

  inView('#flow-grid', () => {
    animate('#flow-grid > div', { opacity: [0, 1], y: [24, 0] }, { duration: 0.45, delay: stagger(0.08) })
  }, { amount: 0.25 })

  inView('#benefits-grid', () => {
    animate('#benefits-grid > div', { opacity: [0, 1], y: [24, 0] }, { duration: 0.45, delay: stagger(0.05) })
  }, { amount: 0.15 })
</script>

<footer class="border-t border-white/10 bg-[#071323] py-10">
  <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-6 px-4 sm:flex-row">
    <div class="flex items-center gap-2">
      <span class="grid h-7 w-7 place-items-center bg-field text-xs font-black text-zinc-950">GA</span>
      <span class="text-sm font-black tracking-[0.18em] text-white/60">GOL AHORA</span>
    </div>
    <p class="text-sm text-white/30">© <%= Date.current.year %> El Buen Deporte. Todos los derechos reservados.</p>
  </div>
</footer>
