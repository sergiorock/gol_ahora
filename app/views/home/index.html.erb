<% content_for :title, "Gol Ahora — El Buen Deporte" %>

<%# ── HERO ─────────────────────────────────────────────────────────── %>
<section class="relative min-h-screen flex items-center overflow-hidden">

  <%# Fondo: césped nocturno con líneas de cancha %>
  <div class="absolute inset-0 bg-pitch">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 60% at 60% 50%, #052e16 0%, #030712 70%);"></div>
    <%# Líneas de cancha %>
    <%#
      SVG cancha de fútbol — medidas escaladas a 6px por metro (campo 105x68m)
      Campo SVG: x=100..700 (600px) × y=80..520 (440px)
      Escala horizontal: 600/105 ≈ 5.7px/m  |  Escala vertical: 440/68 ≈ 6.5px/m
      Usamos 6px/m uniforme para proporciones correctas

      Medidas reglamentarias:
        Círculo central:     r=9.15m  →  55px
        Área grande:         16.5m prof × 40.32m ancho  →  99px × 242px
        Área chica:          5.5m prof × 18.32m ancho   →  33px × 110px
        Punto del penal:     11m del arco                →  66px
        Radio medialuna:     r=9.15m                    →  55px
        Arcos de esquina:    r=1m                        →  6px
    %>
    <svg class="absolute inset-0 w-full h-full opacity-20" viewBox="0 0 800 600" preserveAspectRatio="xMidYMid slice">
      <%# Borde del campo %>
      <rect x="100" y="80" width="600" height="440" fill="none" stroke="#16a34a" stroke-width="2"/>
      <%# Línea del medio %>
      <line x1="400" y1="80" x2="400" y2="520" stroke="#16a34a" stroke-width="2"/>
      <%# Círculo central %>
      <circle cx="400" cy="300" r="55" fill="none" stroke="#16a34a" stroke-width="2"/>
      <%# Punto central %>
      <circle cx="400" cy="300" r="3" fill="#16a34a"/>

      <%# Área grande izquierda (16.5m prof, 20.16m a cada lado del centro del arco) %>
      <rect x="100" y="179" width="99" height="242" fill="none" stroke="#16a34a" stroke-width="2"/>
      <%# Área grande derecha %>
      <rect x="601" y="179" width="99" height="242" fill="none" stroke="#16a34a" stroke-width="2"/>

      <%# Área chica izquierda (5.5m prof, 9.16m a cada lado) %>
      <rect x="100" y="245" width="33" height="110" fill="none" stroke="#16a34a" stroke-width="2"/>
      <%# Área chica derecha %>
      <rect x="667" y="245" width="33" height="110" fill="none" stroke="#16a34a" stroke-width="2"/>

      <%# Punto del penal izquierdo (11m del arco) %>
      <circle cx="166" cy="300" r="3" fill="#16a34a"/>
      <%# Punto del penal derecho %>
      <circle cx="634" cy="300" r="3" fill="#16a34a"/>

      <%#
        Medialuna izquierda: arco de círculo r=55px centrado en el punto del penal (166,300)
        Solo la parte FUERA del área grande (derecha de x=199)
        Intersección con x=199: y = 300 ± sqrt(55²-33²) = 300 ± 44 → y=256 y y=344
        sweep=1 → sentido horario en SVG → el arco curva hacia la derecha (hacia centro cancha)
      %>
      <path d="M 199 256 A 55 55 0 0 1 199 344" fill="none" stroke="#16a34a" stroke-width="2"/>
      <%#
        Medialuna derecha: centrada en (634,300), fuera de x=601
        Intersección con x=601: y = 300 ± 44 → y=256 y y=344
        sweep=0 → sentido antihorario → arco curva hacia la izquierda (hacia centro cancha)
      %>
      <path d="M 601 256 A 55 55 0 0 0 601 344" fill="none" stroke="#16a34a" stroke-width="2"/>

      <%# Arcos de esquina (r=6px) %>
      <path d="M 100 86  A 6 6 0 0 0 106 80"  fill="none" stroke="#16a34a" stroke-width="2"/>
      <path d="M 694 80  A 6 6 0 0 0 700 86"  fill="none" stroke="#16a34a" stroke-width="2"/>
      <path d="M 100 514 A 6 6 0 0 1 106 520" fill="none" stroke="#16a34a" stroke-width="2"/>
      <path d="M 694 520 A 6 6 0 0 1 700 514" fill="none" stroke="#16a34a" stroke-width="2"/>
    </svg>
    <%# Glow verde %>
    <div class="absolute top-1/2 right-1/4 -translate-y-1/2 w-96 h-96 bg-field/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-1/3 w-64 h-64 bg-field/10 rounded-full blur-2xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-20">
    <div class="max-w-3xl">

      <div id="hero-badge" class="inline-flex items-center gap-2 bg-field/20 border border-field/40 rounded-full px-4 py-1.5 text-field-light text-sm font-medium mb-8">
        <span class="w-2 h-2 bg-field-light rounded-full animate-pulse"></span>
        Canchas disponibles ahora
      </div>

      <h1 id="hero-title" class="font-display text-7xl sm:text-8xl lg:text-9xl leading-none tracking-wide mb-6">
        <span class="text-white">RESERVÁ</span><br>
        <span class="text-field-light">TU CANCHA.</span><br>
        <span class="text-white/40">JUGÁ AHORA.</span>
      </h1>

      <p id="hero-sub" class="text-white/60 text-lg sm:text-xl max-w-xl mb-10 leading-relaxed font-light">
        El complejo deportivo <span class="text-white font-medium">El Buen Deporte</span> — canchas de fútbol 5, 7 y 11,
        ligas, torneos y clases con entrenadores certificados.
      </p>

      <div id="hero-cta" class="flex flex-col sm:flex-row gap-4">
        <%= link_to courts_path, class: "inline-flex items-center justify-center gap-2 bg-field hover:bg-field-dark text-white font-semibold px-8 py-4 rounded-xl text-base transition-all hover:shadow-lg hover:shadow-field/30 hover:-translate-y-0.5" do %>
          Reservar cancha
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        <% end %>
        <%= link_to courts_path, class: "inline-flex items-center justify-center gap-2 border border-white/20 hover:border-white/40 text-white font-medium px-8 py-4 rounded-xl text-base transition-all hover:bg-white/5" do %>
          Ver canchas
        <% end %>
      </div>

      <%# Stats %>
      <div id="hero-stats" class="flex gap-8 mt-16 pt-8 border-t border-white/10">
        <div>
          <p class="font-display text-4xl text-field-light">3</p>
          <p class="text-white/50 text-sm mt-1">Tipos de cancha</p>
        </div>
        <div>
          <p class="font-display text-4xl text-field-light">7</p>
          <p class="text-white/50 text-sm mt-1">Días a la semana</p>
        </div>
        <div>
          <p class="font-display text-4xl text-field-light">100%</p>
          <p class="text-white/50 text-sm mt-1">Online</p>
        </div>
      </div>
    </div>
  </div>

</section>

<%# ── SERVICIOS ───────────────────────────────────────────────────── %>
<section id="canchas" class="relative py-24 bg-gray-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-16">
      <p class="text-field-light font-medium text-sm tracking-widest uppercase mb-3">Lo que ofrecemos</p>
      <h2 class="font-display text-5xl sm:text-6xl text-white">NUESTROS SERVICIOS</h2>
    </div>

    <div id="services-grid" class="grid md:grid-cols-3 gap-6">

      <div class="group relative bg-white/5 hover:bg-white/8 border border-white/10 hover:border-field/40 rounded-2xl p-8 transition-all duration-300 hover:-translate-y-1">
        <div class="w-12 h-12 bg-field/20 rounded-xl flex items-center justify-center mb-6 group-hover:bg-field/30 transition-colors">
          <svg class="w-6 h-6 text-field-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
        <h3 class="font-display text-3xl text-white mb-3">RESERVAS ONLINE</h3>
        <p class="text-white/50 leading-relaxed">Reservá tu cancha desde cualquier dispositivo, en cualquier momento. Pagá la seña online y asegurá tu horario.</p>
        <div class="mt-6 flex flex-wrap gap-2">
          <span class="text-xs bg-white/10 text-white/60 px-3 py-1 rounded-full">Fútbol 5</span>
          <span class="text-xs bg-white/10 text-white/60 px-3 py-1 rounded-full">Fútbol 7</span>
          <span class="text-xs bg-white/10 text-white/60 px-3 py-1 rounded-full">Fútbol 11</span>
        </div>
      </div>

      <div class="group relative bg-field/10 hover:bg-field/15 border border-field/30 hover:border-field/60 rounded-2xl p-8 transition-all duration-300 hover:-translate-y-1">
        <div class="w-12 h-12 bg-field/30 rounded-xl flex items-center justify-center mb-6">
          <svg class="w-6 h-6 text-field-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
          </svg>
        </div>
        <h3 class="font-display text-3xl text-white mb-3">LIGAS Y TORNEOS</h3>
        <p class="text-white/50 leading-relaxed">Inscribí tu equipo en competencias organizadas. Seguí el fixture, resultados y tabla de posiciones en tiempo real.</p>
        <div class="mt-6 flex flex-wrap gap-2">
          <span class="text-xs bg-field/20 text-field-light px-3 py-1 rounded-full">Fixture automático</span>
          <span class="text-xs bg-field/20 text-field-light px-3 py-1 rounded-full">Resultados online</span>
        </div>
      </div>

      <div class="group relative bg-white/5 hover:bg-white/8 border border-white/10 hover:border-field/40 rounded-2xl p-8 transition-all duration-300 hover:-translate-y-1">
        <div class="w-12 h-12 bg-field/20 rounded-xl flex items-center justify-center mb-6 group-hover:bg-field/30 transition-colors">
          <svg class="w-6 h-6 text-field-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
        </div>
        <h3 class="font-display text-3xl text-white mb-3">ACADEMIA</h3>
        <p class="text-white/50 leading-relaxed">Clases y entrenamientos con profesores y entrenadores certificados. Mejorá tu juego con seguimiento personalizado.</p>
        <div class="mt-6 flex flex-wrap gap-2">
          <span class="text-xs bg-white/10 text-white/60 px-3 py-1 rounded-full">Profesores certificados</span>
          <span class="text-xs bg-white/10 text-white/60 px-3 py-1 rounded-full">Grupos e individuales</span>
        </div>
      </div>

    </div>
  </div>
</section>

<%# ── TIPOS DE CANCHA ─────────────────────────────────────────────── %>
<section class="py-24 bg-pitch relative overflow-hidden">
  <div class="absolute inset-0" style="background: linear-gradient(135deg, #052e16 0%, transparent 50%);"></div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <p class="text-field-light font-medium text-sm tracking-widest uppercase mb-3">Canchas disponibles</p>
        <h2 class="font-display text-5xl sm:text-6xl text-white mb-6">ELEGÍ TU<br>FORMATO</h2>
        <p class="text-white/50 text-lg leading-relaxed mb-8">Contamos con tres tipos de cancha para que juegues como preferís. Cada formato tiene su duración y precio.</p>
        <% if user_signed_in? %>
          <%= link_to courts_path, class: "inline-flex items-center gap-2 bg-field hover:bg-field-dark text-white font-semibold px-6 py-3 rounded-xl transition-all" do %>
            Ver disponibilidad
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <% end %>
        <% else %>
          <%= link_to new_user_session_path, class: "inline-flex items-center gap-2 bg-field hover:bg-field-dark text-white font-semibold px-6 py-3 rounded-xl transition-all" do %>
            Iniciar sesión para reservar
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <% end %>
        <% end %>
      </div>

      <div id="court-types" class="space-y-4">
        <div class="flex items-center gap-6 bg-white/5 border border-white/10 rounded-2xl p-6 hover:border-field/40 transition-colors">
          <div class="font-display text-5xl text-field-light w-16 text-center">5</div>
          <div class="flex-1">
            <h4 class="font-semibold text-white text-lg">Fútbol 5</h4>
            <p class="text-white/40 text-sm">Hasta 1 hora · Superficie sintética · 10 jugadores</p>
          </div>
          <div class="w-2 h-2 bg-field-light rounded-full"></div>
        </div>
        <div class="flex items-center gap-6 bg-field/10 border border-field/30 rounded-2xl p-6">
          <div class="font-display text-5xl text-field-light w-16 text-center">7</div>
          <div class="flex-1">
            <h4 class="font-semibold text-white text-lg">Fútbol 7</h4>
            <p class="text-white/40 text-sm">Hasta 1.5 horas · Superficie natural · 14 jugadores</p>
          </div>
          <div class="w-2 h-2 bg-field-light rounded-full"></div>
        </div>
        <div class="flex items-center gap-6 bg-white/5 border border-white/10 rounded-2xl p-6 hover:border-field/40 transition-colors">
          <div class="font-display text-5xl text-field-light w-16 text-center">11</div>
          <div class="flex-1">
            <h4 class="font-semibold text-white text-lg">Fútbol 11</h4>
            <p class="text-white/40 text-sm">Hasta 2 horas · Cancha reglamentaria · 22 jugadores</p>
          </div>
          <div class="w-2 h-2 bg-field-light rounded-full"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ── CTA FINAL ───────────────────────────────────────────────────── %>
<% unless user_signed_in? %>
<section class="py-24 bg-gray-950 border-t border-white/5">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <h2 class="font-display text-6xl sm:text-7xl text-white mb-6">¿LISTO PARA<br><span class="text-field-light">JUGAR?</span></h2>
    <p class="text-white/50 text-lg mb-10 max-w-xl mx-auto">Creá tu cuenta gratis y reservá tu primera cancha en minutos.</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <%= link_to "Crear cuenta gratis", new_user_registration_path, class: "inline-flex items-center justify-center gap-2 bg-field hover:bg-field-dark text-white font-semibold px-8 py-4 rounded-xl text-base transition-all hover:shadow-lg hover:shadow-field/30" %>
      <%= link_to "Ya tengo cuenta", new_user_session_path, class: "inline-flex items-center justify-center text-white/60 hover:text-white font-medium px-8 py-4 transition-colors" %>
    </div>
  </div>
</section>
<% end %>

<%# ── ANIMACIONES (Motion vanilla) ───────────────────────────────── %>
<script type="module">
  import { animate, inView, stagger } from 'https://cdn.jsdelivr.net/npm/motion@latest/+esm'

  // Hero: entrada escalonada al cargar
  animate('#hero-badge', { opacity: [0, 1], y: [20, 0] }, { duration: 0.5, delay: 0.1 })
  animate('#hero-title', { opacity: [0, 1], y: [60, 0] }, { duration: 0.7, delay: 0.25, easing: [0.16, 1, 0.3, 1] })
  animate('#hero-sub',   { opacity: [0, 1], y: [30, 0] }, { duration: 0.6, delay: 0.5  })
  animate('#hero-cta',   { opacity: [0, 1], y: [20, 0] }, { duration: 0.5, delay: 0.7  })
  animate('#hero-stats', { opacity: [0, 1], y: [20, 0] }, { duration: 0.5, delay: 0.9  })

  // SVG del fondo: draw-on effect en las líneas de cancha
  const lines = document.querySelectorAll('svg line, svg rect, svg circle, svg path')
  animate(lines, { opacity: [0, 0.1] }, { duration: 1.5, delay: stagger(0.08) })

  // Cards de servicios: aparecen al hacer scroll
  inView('#services-grid', () => {
    animate(
      '#services-grid > div',
      { opacity: [0, 1], y: [40, 0] },
      { duration: 0.5, delay: stagger(0.12), easing: [0.16, 1, 0.3, 1] }
    )
  }, { amount: 0.2 })

  // Sección de tipos de cancha: desliza desde la izquierda
  inView('#court-types', () => {
    animate('#court-types > div', { opacity: [0, 1], x: [-30, 0] }, { duration: 0.5, delay: stagger(0.1) })
  }, { amount: 0.3 })
</script>

<%# ── FOOTER ──────────────────────────────────────────────────────── %>
<footer class="bg-pitch border-t border-white/5 py-8">
  <div class="max-w-7xl mx-auto px-4 flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-2">
      <span class="text-field-light">⚽</span>
      <span class="font-display text-lg tracking-wide text-white/60">GOL AHORA</span>
    </div>
    <p class="text-white/30 text-sm">© <%= Date.current.year %> El Buen Deporte. Todos los derechos reservados.</p>
  </div>
</footer>
