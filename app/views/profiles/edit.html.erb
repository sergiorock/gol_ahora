<% content_for :title, "Editar perfil — Gol Ahora" %>

<div class="max-w-3xl mx-auto pt-24 pb-12 px-4">
  <div class="flex items-center gap-4 mb-8">
    <%= link_to profile_path, class: "text-white/40 hover:text-white transition-colors" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    <% end %>
    <h1 class="font-display text-4xl text-white">EDITAR PERFIL</h1>
  </div>

  <div class="bg-white/5 border border-white/10 rounded-2xl p-8">
    <%= form_with model: current_user, url: profile_path, method: :patch do |f| %>
      <% if current_user.errors.any? %>
        <div class="bg-red-400/10 border border-red-400/20 rounded-xl px-4 py-3 mb-6">
          <% current_user.errors.full_messages.each do |msg| %>
            <p class="text-red-400 text-sm"><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-white/70 mb-1.5">Nombres</label>
          <%= f.text_field :first_name, class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors" %>
        </div>
        <div>
          <label class="block text-sm font-medium text-white/70 mb-1.5">Apellido</label>
          <%= f.text_field :last_name, class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors" %>
        </div>
        <div>
          <label class="block text-sm font-medium text-white/70 mb-1.5">DNI</label>
          <%= f.text_field :dni, class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors" %>
        </div>
        <div>
          <label class="block text-sm font-medium text-white/70 mb-1.5">Teléfono</label>
          <%= f.text_field :phone, class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors" %>
        </div>
        <div>
          <label class="block text-sm font-medium text-white/70 mb-1.5">Fecha de nacimiento</label>
          <%= f.date_field :birth_date, class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors", max: Date.today.strftime("%Y-%m-%d") %>
        </div>
        <div>
          <label class="block text-sm font-medium text-white/70 mb-1.5">Código postal</label>
          <%= f.text_field :postal_code, class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors" %>
        </div>
        <div class="sm:col-span-2">
          <label class="block text-sm font-medium text-white/70 mb-1.5">Domicilio</label>
          <%= f.text_field :address, class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors" %>
        </div>
        <div>
          <label class="block text-sm font-medium text-white/70 mb-1.5">País</label>
          <%= f.country_select :country,
              { priority_countries: %w[AR UY CL BR PY BO], selected: current_user.country.presence || "AR", include_blank: "Seleccioná un país" },
              { class: "country-tomselect", data: { placeholder: "Seleccioná un país" } } %>
        </div>
        <div>
          <label class="block text-sm font-medium text-white/70 mb-1.5">Provincia / Estado</label>
          <div id="province-select-wrap">
            <%= f.select :province,
                options_for_select(User::PROVINCIAS, current_user.province.presence || "Buenos Aires"),
                { include_blank: "Seleccioná una provincia" },
                { class: "ts-dark", data: { placeholder: "Seleccioná una provincia" } } %>
          </div>
          <div id="province-text-wrap" class="hidden">
            <%= f.text_field :province,
                class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors",
                placeholder: "Provincia / Estado",
                id: "province-text-input",
                disabled: true %>
          </div>
        </div>
        <div class="sm:col-span-2">
          <label class="block text-sm font-medium text-white/70 mb-1.5">Ciudad</label>
          <%= f.text_field :city, class: "w-full bg-white/5 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-field-light focus:ring-1 focus:ring-field-light transition-colors" %>
        </div>
        <script>
          document.addEventListener("DOMContentLoaded", function() {
            function toggleProvince() {
              var country = document.querySelector("select[name='user[country]']");
              if (!country) return;
              var isAR = country.value === "AR";
              document.getElementById("province-select-wrap").classList.toggle("hidden", !isAR);
              document.getElementById("province-text-wrap").classList.toggle("hidden", isAR);
              document.getElementById("province-text-input").disabled = isAR;
              if (!isAR) document.querySelector("select[name='user[province]']").value = "";
            }
            var countryEl = document.querySelector("select[name='user[country]']");
            if (countryEl) { countryEl.addEventListener("change", toggleProvince); toggleProvince(); }
          });
        </script>
      </div>

      <div class="flex gap-3 mt-8">
        <%= f.submit "Guardar cambios", class: "bg-field hover:bg-field-dark text-white font-semibold px-6 py-3 rounded-xl transition-colors" %>
        <%= link_to "Cancelar", profile_path, class: "text-white/50 hover:text-white font-medium px-6 py-3 transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
