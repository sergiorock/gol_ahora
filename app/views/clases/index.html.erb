<% content_for :title, "Clases — Gol Ahora" %>

<div class="max-w-5xl mx-auto pt-24 pb-16 px-4">

  <div class="mb-12">
    <p class="text-field-light text-sm font-medium tracking-widest uppercase mb-2">El Buen Deporte</p>
    <h1 class="font-display text-6xl sm:text-8xl text-white leading-none">CLASES</h1>
    <div class="w-16 h-1 bg-field mt-4"></div>
  </div>

  <% if @clases.any? %>
    <div class="grid sm:grid-cols-2 gap-4">
      <% @clases.each do |clase| %>
        <%= link_to clase_path(clase), class: "group bg-white/5 border border-white/10 hover:border-field/50 rounded-2xl p-6 transition-all duration-300 block" do %>
          <div class="flex items-start justify-between gap-3 mb-4">
            <div class="flex flex-wrap gap-2">
              <% if clase.court_type %>
                <span class="text-xs px-2.5 py-1 rounded-full bg-blue-500/20 text-blue-400 font-medium">
                  <%= clase.court_type.name %>
                </span>
              <% end %>
              <% if clase.full? %>
                <span class="text-xs px-2.5 py-1 rounded-full bg-red-500/20 text-red-400 font-medium">Sin cupo</span>
              <% else %>
                <span class="text-xs px-2.5 py-1 rounded-full bg-orange-500/20 text-orange-400 font-medium">
                  <%= clase.spots_available %> lugar<%= clase.spots_available == 1 ? "" : "es" %>
                </span>
              <% end %>
            </div>
          </div>

          <h3 class="font-display text-3xl text-white mb-1 group-hover:text-field-light transition-colors">
            <%= clase.nombre.upcase %>
          </h3>
          <p class="text-white/50 text-sm mb-1 flex items-center gap-2">
            Prof. <%= clase.personal_deportivo.full_name %>
            <% if clase.personal_deportivo.certificacion_archivo.attached? %>
              <span class="text-xs bg-orange-500/20 text-orange-400 px-2 py-0.5 rounded-full font-medium">Certificado</span>
            <% end %>
          </p>
          <% if clase.descripcion.present? %>
            <p class="text-white/40 text-sm mb-4 line-clamp-2"><%= clase.descripcion %></p>
          <% else %>
            <div class="mb-4"></div>
          <% end %>

          <div class="flex items-center gap-5 text-white/40 text-xs border-t border-white/5 pt-4">
            <span><%= clase.schedule_label %></span>
            <span><%= clase.duration_minutes %> min</span>
            <span><%= clase.spots_taken %>/<%= clase.max_students %> inscriptos</span>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-24 text-white/30">
      <p class="text-lg">No hay clases disponibles por el momento.</p>
    </div>
  <% end %>

</div>
