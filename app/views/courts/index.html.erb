<% content_for :title, "Canchas — Gol Ahora" %>

<div class="max-w-7xl mx-auto pt-24 pb-16 px-4">

  <div class="mb-10">
    <p class="text-field-light text-sm font-medium tracking-widest uppercase mb-2">El Buen Deporte</p>
    <h1 class="font-display text-5xl sm:text-6xl text-white">NUESTRAS CANCHAS</h1>
  </div>

  <%# Filtros combinables: tamaño + superficie %>
  <div class="space-y-3 mb-8">
    <%# Fila 1: tamaño %>
    <div class="flex flex-wrap items-center gap-2">
      <span class="text-white/30 text-xs uppercase tracking-widest w-20">Tamaño</span>
      <%= link_to courts_path(surface: params[:surface]),
            class: "px-4 py-1.5 rounded-full text-sm font-medium transition-all #{params[:size].blank? ? 'bg-field text-white' : 'border border-white/20 text-white/60 hover:text-white'}" do %>
        Todos
      <% end %>
      <% @sizes.each do |size| %>
        <%= link_to courts_path(size: size, surface: params[:surface]),
              class: "px-4 py-1.5 rounded-full text-sm font-medium transition-all #{params[:size]&.to_i == size ? 'bg-field text-white' : 'border border-white/20 text-white/60 hover:text-white'}" do %>
          Fútbol <%= size %>
        <% end %>
      <% end %>
    </div>

    <%# Fila 2: superficie %>
    <div class="flex flex-wrap items-center gap-2">
      <span class="text-white/30 text-xs uppercase tracking-widest w-20">Superficie</span>
      <%= link_to courts_path(size: params[:size]),
            class: "px-4 py-1.5 rounded-full text-sm font-medium transition-all #{params[:surface].blank? ? 'bg-field text-white' : 'border border-white/20 text-white/60 hover:text-white'}" do %>
        Todas
      <% end %>
      <% @surfaces.each do |surface| %>
        <%= link_to courts_path(size: params[:size], surface: surface),
              class: "px-4 py-1.5 rounded-full text-sm font-medium transition-all #{params[:surface] == surface ? 'bg-field text-white' : 'border border-white/20 text-white/60 hover:text-white'}" do %>
          <%= CourtType::SURFACE_LABELS[surface] %>
        <% end %>
      <% end %>
    </div>
  </div>

  <% if @courts.any? %>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @courts.each do |court| %>
        <div class="group bg-white/5 border border-white/10 hover:border-field/40 rounded-2xl overflow-hidden transition-all hover:-translate-y-1 duration-300">
          <div class="h-32 relative overflow-hidden">
            <%= court_surface_svg(court.court_type, css_class: "absolute inset-0 w-full h-full") %>
            <div class="absolute inset-0 flex items-center justify-center">
              <span class="font-display text-6xl text-white drop-shadow-lg">
                <%= court.court_type.name[/\d+/] || "⚽" %>
              </span>
            </div>
          </div>

          <div class="p-6">
            <div class="flex items-start justify-between mb-3">
              <div>
                <h3 class="font-semibold text-white text-lg"><%= court.name %></h3>
                <p class="text-white/50 text-sm"><%= court.court_type.name %></p>
              </div>
              <span class="text-field-light font-display text-2xl">$<%= number_with_delimiter(court.court_type.price_per_hour) %><span class="text-white/40 text-sm font-body">/h</span></span>
            </div>

            <div class="flex flex-wrap gap-2 mb-5">
              <span class="text-xs bg-white/10 text-white/60 px-3 py-1 rounded-full">
                <i class="ti ti-users"></i> <%= court.court_type.capacity %> jugadores
              </span>
              <span class="text-xs bg-white/10 text-white/60 px-3 py-1 rounded-full">
                <i class="ti ti-clock"></i> Máx. <%= court.court_type.duration_label %>
              </span>
              <% if court.court_type.surface.present? %>
                <span class="text-xs bg-white/10 text-white/60 px-3 py-1 rounded-full">
                  <%= CourtType::SURFACE_LABELS[court.court_type.surface] %>
                </span>
              <% end %>
            </div>

            <%= link_to new_reservation_path(court_id: court.id), class: "block w-full text-center #{user_signed_in? ? 'bg-field hover:bg-field-dark text-white font-semibold' : 'border border-field/40 hover:bg-field/10 text-field-light font-medium'} py-2.5 rounded-xl transition-colors text-sm" do %>
              <%= user_signed_in? ? "Reservar ahora" : "Iniciá sesión para reservar" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16 text-white/40">
      <p class="text-lg">No hay canchas disponibles en este momento.</p>
    </div>
  <% end %>
</div>
