<% content_for :page_title, "Reserva ##{@reservation.id}" %>
<% content_for :header_actions do %>
  <%= link_to admin_reservations_path, class: "btn btn-secondary" do %>
    <i class="ti ti-arrow-left"></i> Volver
  <% end %>
  <% if @reservation.may_cancel? %>
    <%= link_to edit_admin_reservation_path(@reservation), class: "btn btn-warning" do %>
      <i class="ti ti-pencil"></i> Editar
    <% end %>
  <% end %>
  <% balance = @reservation.total_amount.to_i - @reservation.deposit_amount.to_i %>
  <% if @reservation.balance_charge %>
    <span class="btn btn-ghost-success disabled">
      <i class="ti ti-check me-1"></i> Saldo cobrado
    </span>
  <% else %>
    <%= link_to new_admin_charge_path(
          prefill_user:        @reservation.user_id,
          prefill_amount:      balance,
          prefill_concept:     "Saldo reserva #{@reservation.court.name} #{l @reservation.starts_at, format: '%-d/%m/%Y %H:%M'}",
          prefill_type:        "rental",
          prefill_reservation: @reservation.id
        ), class: "btn btn-success" do %>
      <i class="ti ti-cash me-1"></i> Registrar saldo ($<%= number_with_delimiter(balance) %>)
    <% end %>
  <% end %>
<% end %>

<div class="row g-4">
  <div class="col-lg-7">
    <%# Datos de la reserva %>
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">Detalle de la reserva</h3>
        <div class="card-options">
          <%= reservation_status_badge(@reservation.status) %>
        </div>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-6">
            <label class="form-label text-muted small">Cliente</label>
            <p class="fw-semibold mb-0"><%= @reservation.user.full_name %></p>
            <p class="text-muted small"><%= @reservation.user.email %></p>
          </div>
          <div class="col-6">
            <label class="form-label text-muted small">Cancha</label>
            <p class="fw-semibold mb-0"><%= @reservation.court.name %></p>
            <p class="text-muted small"><%= @reservation.court.court_type.name %> · <%= CourtType::SURFACE_LABELS[@reservation.court.court_type.surface] %></p>
          </div>
          <div class="col-6">
            <label class="form-label text-muted small">Fecha y horario</label>
            <p class="fw-semibold mb-0"><%= l @reservation.starts_at, format: "%-d de %B %Y" %></p>
            <p class="text-muted small"><%= l @reservation.starts_at, format: "%H:%M" %> – <%= l @reservation.ends_at, format: "%H:%M" %> (<%= @reservation.duration_minutes %> min)</p>
          </div>
          <div class="col-6">
            <label class="form-label text-muted small">Total del turno</label>
            <p class="fw-bold fs-3 mb-0">$<%= number_with_delimiter(@reservation.total_amount.to_i) %></p>
          </div>
          <% if @reservation.notes.present? %>
            <div class="col-12">
              <label class="form-label text-muted small">Notas</label>
              <p class="mb-0"><%= @reservation.notes %></p>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <%# Resumen financiero %>
    <% deposit    = @reservation.deposit_charge %>
    <% balance_c  = @reservation.balance_charge %>
    <% total      = @reservation.total_amount.to_i %>
    <% paid_total = (deposit&.amount.to_i + balance_c&.amount.to_i) %>
    <% pending    = total - paid_total %>

    <div class="card mt-3">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h3 class="card-title mb-0">Resumen financiero</h3>
        <% if pending <= 0 %>
          <span class="badge bg-success"><i class="ti ti-check me-1"></i>Pago completo</span>
        <% else %>
          <span class="badge bg-warning text-dark"><i class="ti ti-clock me-1"></i>Pendiente $<%= number_with_delimiter(pending) %></span>
        <% end %>
      </div>
      <div class="table-responsive">
        <table class="table table-vcenter card-table">
          <thead>
            <tr><th>Concepto</th><th>Método</th><th>Detalle</th><th class="text-end">Monto</th><th>Estado</th></tr>
          </thead>
          <tbody>
            <% is_walkin = @reservation.deposit_amount.to_i == 0 %>

            <%# Seña online — solo si no es walk-in %>
            <% unless is_walkin %>
              <% if @payments.any? %>
                <% @payments.each do |p| %>
                  <tr>
                    <td><strong>Seña (30%)</strong><div class="text-muted small">Pago online</div></td>
                    <td><span class="badge bg-blue-lt">Tarjeta</span></td>
                    <td class="text-muted small">•••• <%= p.last_four_digits %> · <%= p.cardholder_name %></td>
                    <td class="text-end fw-semibold">$<%= number_with_delimiter(p.amount.to_i) %></td>
                    <td><span class="badge bg-success-lt">Aprobado</span></td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td><strong>Seña (30%)</strong></td>
                  <td>—</td><td>—</td>
                  <td class="text-end">$<%= number_with_delimiter(@reservation.deposit_amount.to_i) %></td>
                  <td><span class="badge bg-warning-lt">Pendiente</span></td>
                </tr>
              <% end %>
            <% end %>

            <%# Saldo / Pago total %>
            <tr class="<%= balance_c ? '' : 'table-warning' %>">
              <td>
                <strong><%= is_walkin ? "Pago total" : "Saldo (70%)" %></strong>
                <div class="text-muted small"><%= is_walkin ? "Cobro presencial" : "Cobro presencial" %></div>
              </td>
              <td>
                <% if balance_c %>
                  <span class="badge bg-blue-lt"><%= t("charge.payment_methods.#{balance_c.payment_method}") %></span>
                <% else %>—<% end %>
              </td>
              <td class="text-muted small">
                <% if balance_c %>
                  <%= link_to admin_charge_path(balance_c), class: "text-muted" do %>
                    Cobro #<%= balance_c.id %>
                  <% end %>
                <% else %>Sin registrar<% end %>
              </td>
              <td class="text-end fw-semibold">$<%= number_with_delimiter(total - @reservation.deposit_amount.to_i) %></td>
              <td>
                <% if balance_c %>
                  <span class="badge bg-success-lt">Cobrado</span>
                <% else %>
                  <span class="badge bg-warning-lt">Pendiente</span>
                <% end %>
              </td>
            </tr>

            <%# Total %>
            <tr class="fw-bold">
              <td colspan="3" class="text-end text-muted">Total cobrado</td>
              <td class="text-end fs-5">$<%= number_with_delimiter(paid_total) %></td>
              <td></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <%# Panel de acciones %>
  <div class="col-lg-5">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">Cambiar estado</h3>
      </div>
      <div class="card-body">
        <% transitions = {
             "confirmed" => { label: "Confirmar",         icon: "check", css: "btn-success" },
             "finished"  => { label: "Marcar finalizada", icon: "flag",  css: "btn-secondary" },
             "cancelled" => { label: "Cancelar reserva",  icon: "x",     css: "btn-danger" }
           } %>

        <div class="d-grid gap-2">
          <% transitions.each do |status, opts| %>
            <% event = { "confirmed" => :confirm, "in_progress" => :start, "finished" => :finish, "cancelled" => :cancel }[status] %>
            <% if @reservation.send(:"may_#{event}?") %>
              <%= button_to admin_reservation_path(@reservation),
                    method: :patch,
                    params: { reservation: { status: status } },
                    class: "btn #{opts[:css]}" do %>
                <i class="ti ti-<%= opts[:icon] %> me-1"></i> <%= opts[:label] %>
              <% end %>
            <% end %>
          <% end %>
        </div>

        <% if [:finished, :cancelled].include?(@reservation.aasm.current_state) %>
          <p class="text-muted small mt-3 mb-0 text-center">No hay transiciones disponibles para este estado.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
