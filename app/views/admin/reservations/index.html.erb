<% content_for :page_title, "Reservas" %>

<div class="card">
  <%# Filtros %>
  <div class="card-header">
    <%= form_with url: admin_reservations_path, method: :get, class: "row g-2 align-items-end" do |f| %>
      <div class="col-auto">
        <%= f.select :status,
              [["Todos los estados", ""]] + Reservation.aasm.states.map { |s| [t("reservation.statuses.#{s.name}", default: s.name.to_s.humanize), s.name] },
              { selected: params[:status] },
              class: "form-select form-select-sm" %>
      </div>
      <div class="col-auto">
        <%= f.select :court_id,
              [["Todas las canchas", ""]] + Court.order(:name).pluck(:name, :id),
              { selected: params[:court_id] },
              class: "form-select form-select-sm" %>
      </div>
      <div class="col-auto">
        <%= f.text_field :from, value: params[:from], placeholder: "Desde (YYYY-MM-DD)",
              class: "form-control form-control-sm" %>
      </div>
      <div class="col-auto">
        <%= f.submit "Filtrar", class: "btn btn-sm btn-secondary" %>
        <%= link_to "Limpiar", admin_reservations_path, class: "btn btn-sm btn-ghost-secondary" %>
      </div>
    <% end %>
  </div>

  <div class="table-responsive">
    <table class="table table-vcenter card-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Cliente</th>
          <th>Cancha</th>
          <th>Horario</th>
          <th>Total</th>
          <th>Estado</th>
          <th>Cobro</th>
          <th class="w-1">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% @reservations.each do |r| %>
          <tr>
            <td class="text-muted">#<%= r.id %></td>
            <td>
              <div class="fw-semibold"><%= r.user.full_name %></div>
              <div class="text-muted small"><%= r.user.email %></div>
            </td>
            <td>
              <div class="fw-semibold"><%= r.court.name %></div>
              <div class="text-muted small"><%= r.court.court_type.name %> · <%= CourtType::SURFACE_LABELS[r.court.court_type.surface] %></div>
            </td>
            <td>
              <div><%= l r.starts_at, format: "%-d %b %Y" %></div>
              <div class="text-muted small"><%= l r.starts_at, format: "%H:%M" %> – <%= l r.ends_at, format: "%H:%M" %></div>
            </td>
            <td>$<%= number_with_delimiter(r.total_amount.to_i) %></td>
            <td><%= reservation_status_badge(r.status) %></td>
            <td>
              <% if r.confirmed? || r.in_progress? %>
                <% if r.balance_charge %>
                  <span class="badge bg-primary-lt">Saldo cobrado</span>
                <% else %>
                  <span class="badge bg-warning-lt">Saldo pendiente</span>
                <% end %>
              <% elsif r.finished? %>
                <span class="badge bg-primary-lt">Pagada</span>
              <% elsif r.cancelled? %>
                <span class="badge bg-secondary-lt">—</span>
              <% else %>
                <span class="badge bg-warning-lt">Seña pendiente</span>
              <% end %>
            </td>
            <td>
              <%= link_to admin_reservation_path(r), class: "btn btn-sm btn-ghost-secondary" do %>
                <i class="ti ti-eye"></i>
              <% end %>
              <% if r.may_cancel? %>
                <%= link_to edit_admin_reservation_path(r), class: "btn btn-sm btn-ghost-warning" do %>
                  <i class="ti ti-pencil"></i>
                <% end %>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @reservations.empty? %>
          <tr><td colspan="8" class="text-center text-muted py-4">No hay reservas.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
