<%= simple_form_for [:admin, competition, match] do |f| %>
  <% if match.errors.any? %>
    <div class="alert alert-danger"><ul class="mb-0"><% match.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul></div>
  <% end %>
  <div class="row g-3">
    <div class="col-md-5"><%= f.input :home_team, label: "Equipo local" %></div>
    <div class="col-md-2 d-flex align-items-end justify-content-center pb-3"><span class="fw-bold text-muted">vs</span></div>
    <div class="col-md-5"><%= f.input :away_team, label: "Equipo visitante" %></div>
    <div class="col-md-3">
      <%= f.input :home_goals, label: "Goles local", placeholder: "—",
            input_html: { min: 0, type: "number" } %>
    </div>
    <div class="col-md-3">
      <%= f.input :away_goals, label: "Goles visitante", placeholder: "—",
            input_html: { min: 0, type: "number" } %>
    </div>
    <div class="col-md-3">
      <%= f.input :played_at, label: "Fecha y hora", as: :string,
            input_html: { type: "datetime-local", value: match.played_at&.strftime("%Y-%m-%dT%H:%M") } %>
    </div>
    <div class="col-md-3">
      <%= f.input :court_id, label: "Cancha (opcional)",
            collection: @courts, value_method: :id, label_method: :name,
            include_blank: "Sin asignar" %>
    </div>
    <div class="col-12">
      <%= f.input :official_rules, label: "Reglas oficiales (opcional)", as: :text, input_html: { rows: 2 } %>
    </div>
  </div>
  <div class="d-flex gap-2 mt-3">
    <%= f.button :submit, match.persisted? ? "Guardar cambios" : "Agregar partido", class: "btn btn-primary" %>
    <%= link_to "Cancelar", competition_type == :league ? admin_league_path(competition) : admin_tournament_path(competition), class: "btn btn-ghost-secondary" %>
  </div>
<% end %>
