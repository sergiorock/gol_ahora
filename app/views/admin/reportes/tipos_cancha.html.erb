<% content_for :page_title, "Tipos de Cancha y Características" %>
<% content_for :header_actions do %>
  <%= link_to tipos_cancha_admin_reportes_path(format: :pdf),
      class: "btn btn-sm d-inline-flex align-items-center gap-1",
      style: "background:#16a34a;color:#fff;border-color:#16a34a;",
      target: "_blank" do %>
    <i class="ti ti-file-type-pdf"></i> Descargar PDF
  <% end %>
<% end %>

<% surface_labels = { "synthetic" => "Césped sintético", "natural" => "Césped natural", "parquet" => "Parquet", "cement" => "Cemento" } %>

<div class="card">
  <div class="card-header">
    <h3 class="card-title"><%= @court_types.count %> tipos de cancha registrados</h3>
  </div>
  <div class="table-responsive">
    <table class="table table-vcenter card-table">
      <thead>
        <tr>
          <th>Nombre</th>
          <th>Superficie</th>
          <th class="text-center">Capacidad</th>
          <th>Duración máx.</th>
          <th class="text-end">Precio/hora</th>
          <th class="text-center">Canchas activas</th>
        </tr>
      </thead>
      <tbody>
        <% @court_types.each do |ct| %>
          <tr>
            <td class="fw-medium"><%= ct.name %></td>
            <td>
              <span class="badge bg-azure-lt text-azure"><%= surface_labels[ct.surface] || ct.surface %></span>
            </td>
            <td class="text-center"><%= ct.capacity %> personas</td>
            <td class="text-muted"><%= ct.duration_label %></td>
            <td class="text-end fw-semibold">$<%= number_with_delimiter(ct.price_per_hour.to_i, delimiter: ".") %></td>
            <td class="text-center">
              <span class="badge <%= ct.courts.count > 0 ? "bg-success-lt text-success" : "bg-secondary-lt text-secondary" %>">
                <%= ct.courts.count %>
              </span>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
