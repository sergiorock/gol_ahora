<% content_for :page_title, "Reporte de Cobros" %>
<% content_for :header_actions do %>
  <%= link_to cobros_admin_reportes_path(request.query_parameters.merge(format: :pdf)),
      class: "btn btn-sm d-inline-flex align-items-center gap-1",
      style: "background:#16a34a;color:#fff;border-color:#16a34a;",
      target: "_blank" do %>
    <i class="ti ti-file-type-pdf"></i> Descargar PDF
  <% end %>
<% end %>

<div class="card mb-4">
  <div class="card-header">
    <h3 class="card-title"><i class="ti ti-filter me-1"></i>Filtros</h3>
  </div>
  <div class="card-body">
    <%= form_with url: cobros_admin_reportes_path, method: :get, local: true do |f| %>
      <div class="row g-3 align-items-end">
        <div class="col-sm-6 col-md-3">
          <label class="form-label">Tipo de cobro</label>
          <%= f.select :charge_type,
              [["Todos los tipos", ""],
               ["Alquiler", "rental"], ["Inscripción", "enrollment"],
               ["Clase", "class_fee"], ["Otro", "other"]],
              { selected: params[:charge_type] },
              class: "form-select form-select-sm" %>
        </div>
        <div class="col-sm-6 col-md-2">
          <label class="form-label">Desde</label>
          <%= f.date_field :desde, value: params[:desde], class: "form-control form-control-sm" %>
        </div>
        <div class="col-sm-6 col-md-2">
          <label class="form-label">Hasta</label>
          <%= f.date_field :hasta, value: params[:hasta], class: "form-control form-control-sm" %>
        </div>
        <div class="col-md-2 d-flex gap-2">
          <%= f.submit "Filtrar", class: "btn btn-sm btn-primary flex-fill" %>
          <%= link_to "Limpiar", cobros_admin_reportes_path, class: "btn btn-sm btn-ghost-secondary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-sm-6 col-xl-4">
    <div class="card">
      <div class="card-body p-3 text-center">
        <div class="text-muted small mb-1">Total cobros</div>
        <div class="h2 mb-0"><%= @charges.count %></div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-4">
    <div class="card">
      <div class="card-body p-3 text-center">
        <div class="text-muted small mb-1">Monto total</div>
        <div class="h2 mb-0 text-primary">$<%= number_with_delimiter(@total.to_i, delimiter: ".") %></div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-4">
    <div class="card">
      <div class="card-body p-3 text-center">
        <div class="text-muted small mb-1">Promedio por cobro</div>
        <div class="h2 mb-0">$<%= @charges.count > 0 ? number_with_delimiter((@total / @charges.count).to_i, delimiter: ".") : 0 %></div>
      </div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <h3 class="card-title"><%= @charges.count %> cobro<%= @charges.count == 1 ? "" : "s" %></h3>
  </div>
  <% if @charges.any? %>
    <div class="table-responsive">
      <table class="table table-vcenter table-hover card-table">
        <thead>
          <tr>
            <th>Fecha</th>
            <th>Concepto</th>
            <th>Tipo</th>
            <th>Método</th>
            <th>Cliente</th>
            <th class="text-end">Monto</th>
            <th class="w-1"></th>
          </tr>
        </thead>
        <tbody>
          <% tipo_labels = { "rental" => "Alquiler", "enrollment" => "Inscripción", "class_fee" => "Clase", "other" => "Otro" } %>
          <% method_labels = { "cash" => "Efectivo", "transfer" => "Transferencia", "card" => "Tarjeta" } %>
          <% @charges.each do |c| %>
            <tr>
              <td class="text-nowrap"><%= l c.date, format: "%-d %b %Y" %></td>
              <td><%= truncate(c.concept, length: 40) %></td>
              <td><span class="badge bg-blue-lt text-blue"><%= tipo_labels[c.charge_type] || c.charge_type %></span></td>
              <td class="text-muted"><%= method_labels[c.payment_method] || c.payment_method %></td>
              <td><%= c.user.full_name %></td>
              <td class="text-end fw-semibold">$<%= number_with_delimiter(c.amount.to_i, delimiter: ".") %></td>
              <td>
                <%= link_to admin_charge_path(c), class: "btn btn-sm btn-ghost-secondary" do %>
                  <i class="ti ti-eye"></i>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="card-body">
      <div class="empty py-5">
        <div class="empty-icon"><i class="ti ti-cash-off text-muted" style="font-size:2.5rem"></i></div>
        <p class="empty-title mt-3">Sin resultados</p>
        <p class="empty-subtitle text-muted">No hay cobros con los filtros seleccionados.</p>
      </div>
    </div>
  <% end %>
</div>
