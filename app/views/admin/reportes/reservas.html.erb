<% content_for :page_title, "Reporte de Reservas" %>
<% content_for :header_actions do %>
  <%= link_to reservas_admin_reportes_path(request.query_parameters.merge(format: :pdf)),
      class: "btn btn-sm d-inline-flex align-items-center gap-1",
      style: "background:#16a34a;color:#fff;border-color:#16a34a;",
      target: "_blank" do %>
    <i class="ti ti-file-type-pdf"></i> Descargar PDF
  <% end %>
<% end %>

<%# Filtros %>
<div class="card mb-4">
  <div class="card-header">
    <h3 class="card-title"><i class="ti ti-filter me-1"></i>Filtros</h3>
  </div>
  <div class="card-body">
    <%= form_with url: reservas_admin_reportes_path, method: :get, local: true do |f| %>
      <div class="row g-3 align-items-end">
        <div class="col-sm-6 col-md-3">
          <label class="form-label">Estado</label>
          <%= f.select :status,
              [["Todos los estados", ""],
               ["Pendiente", "pending"], ["Confirmada", "confirmed"],
               ["En curso", "in_progress"], ["Finalizada", "finished"], ["Cancelada", "cancelled"]],
              { selected: params[:status] },
              class: "form-select form-select-sm" %>
        </div>
        <div class="col-sm-6 col-md-3">
          <label class="form-label">Cancha</label>
          <%= f.select :court_id,
              [["Todas las canchas", ""]] + @courts.map { |c| [c.name, c.id] },
              { selected: params[:court_id] },
              class: "form-select form-select-sm" %>
        </div>
        <div class="col-sm-6 col-md-2">
          <label class="form-label">Desde</label>
          <%= f.date_field :desde, value: params[:desde], class: "form-control form-control-sm" %>
        </div>
        <div class="col-sm-6 col-md-2">
          <label class="form-label">Hasta</label>
          <%= f.date_field :hasta, value: params[:hasta], class: "form-control form-control-sm" %>
        </div>
        <div class="col-md-2 d-flex gap-2">
          <%= f.submit "Filtrar", class: "btn btn-sm btn-primary flex-fill" %>
          <%= link_to "Limpiar", reservas_admin_reportes_path, class: "btn btn-sm btn-ghost-secondary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<%# Resumen stats %>
<div class="row g-3 mb-4">
  <div class="col-sm-6 col-xl-3">
    <div class="card">
      <div class="card-body p-3 text-center">
        <div class="text-muted small mb-1">Total reservas</div>
        <div class="h2 mb-0"><%= @reservations.count %></div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card">
      <div class="card-body p-3 text-center">
        <div class="text-muted small mb-1">Confirmadas/Finalizadas</div>
        <div class="h2 mb-0 text-green"><%= @reservations.select { |r| %w[confirmed finished in_progress].include?(r.status) }.count %></div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card">
      <div class="card-body p-3 text-center">
        <div class="text-muted small mb-1">Canceladas</div>
        <div class="h2 mb-0 text-red"><%= @reservations.select { |r| r.status == "cancelled" }.count %></div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card">
      <div class="card-body p-3 text-center">
        <div class="text-muted small mb-1">Monto total</div>
        <div class="h2 mb-0">$<%= number_with_delimiter(@reservations.sum(:total_amount).to_i, delimiter: ".") %></div>
      </div>
    </div>
  </div>
</div>

<%# Tabla %>
<div class="card">
  <div class="card-header">
    <h3 class="card-title">
      <%= @reservations.count %> reserva<%= @reservations.count == 1 ? "" : "s" %> encontrada<%= @reservations.count == 1 ? "" : "s" %>
    </h3>
  </div>
  <% if @reservations.any? %>
    <div class="table-responsive">
      <table class="table table-vcenter table-hover card-table">
        <thead>
          <tr>
            <th>Fecha</th>
            <th>Horario</th>
            <th>Cancha</th>
            <th>Cliente</th>
            <th>Estado</th>
            <th class="text-end">Monto</th>
            <th class="w-1"></th>
          </tr>
        </thead>
        <tbody>
          <% @reservations.each do |r| %>
            <tr>
              <td class="text-nowrap"><%= l r.starts_at, format: "%-d %b %Y" %></td>
              <td class="text-muted text-nowrap"><%= r.starts_at.strftime("%H:%M") %> – <%= r.ends_at.strftime("%H:%M") %></td>
              <td><%= r.court.name %></td>
              <td>
                <div class="d-flex align-items-center gap-2">
                  <span class="avatar avatar-xs rounded-circle bg-blue-lt text-blue"><%= r.user.first_name[0] %></span>
                  <%= r.user.full_name %>
                </div>
              </td>
              <td><%= reservation_status_badge(r.status) %></td>
              <td class="text-end fw-medium">$<%= number_with_delimiter(r.total_amount.to_i, delimiter: ".") %></td>
              <td>
                <%= link_to admin_reservation_path(r), class: "btn btn-sm btn-ghost-secondary" do %>
                  <i class="ti ti-eye"></i>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="card-body">
      <div class="empty py-5">
        <div class="empty-icon"><i class="ti ti-calendar-off text-muted" style="font-size:2.5rem"></i></div>
        <p class="empty-title mt-3">Sin resultados</p>
        <p class="empty-subtitle text-muted">No hay reservas con los filtros seleccionados.</p>
      </div>
    </div>
  <% end %>
</div>
