<% content_for :page_title, @personal_deportivo.full_name %>
<% content_for :header_actions do %>
  <%= link_to admin_personal_deportivos_path, class: "btn btn-secondary" do %>
    <i class="ti ti-arrow-left"></i> Volver
  <% end %>
  <%= link_to edit_admin_personal_deportivo_path(@personal_deportivo), class: "btn btn-warning" do %>
    <i class="ti ti-pencil"></i> Editar
  <% end %>
<% end %>

<div class="row g-4">
  <div class="col-lg-4">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">Datos</h3>
        <div class="card-options">
          <span class="badge <%= @personal_deportivo.tipo_profesor? ? 'bg-blue-lt' : 'bg-purple-lt' %>">
            <%= PersonalDeportivo::TIPO_LABELS[@personal_deportivo.tipo] %>
          </span>
        </div>
      </div>
      <div class="card-body">
        <dl class="row g-2">
          <dt class="col-5 text-muted">Nombre</dt>
          <dd class="col-7"><%= @personal_deportivo.full_name %></dd>
          <dt class="col-5 text-muted">Email</dt>
          <dd class="col-7"><%= @personal_deportivo.email.presence || "—" %></dd>
          <dt class="col-5 text-muted">Teléfono</dt>
          <dd class="col-7"><%= @personal_deportivo.telefono.presence || "—" %></dd>
          <dt class="col-5 text-muted">Certificación</dt>
          <dd class="col-7"><%= @personal_deportivo.certificacion_deportiva.presence || "—" %></dd>
          <dt class="col-5 text-muted">Fecha cert.</dt>
          <dd class="col-7"><%= @personal_deportivo.fecha_certificacion ? l(@personal_deportivo.fecha_certificacion, format: :long) : "—" %></dd>
          <dt class="col-5 text-muted">Archivo</dt>
          <dd class="col-7">
            <% if @personal_deportivo.certificacion_archivo.attached? %>
              <%= link_to "Ver certificado", rails_blob_path(@personal_deportivo.certificacion_archivo, disposition: "inline"),
                  target: "_blank", class: "btn btn-sm btn-outline-success" %>
            <% else %>
              —
            <% end %>
          </dd>
          <dt class="col-5 text-muted">Observaciones</dt>
          <dd class="col-7"><%= @personal_deportivo.observaciones.presence || "—" %></dd>
        </dl>
      </div>
    </div>
  </div>

  <div class="col-lg-8">
    <% if @personal_deportivo.tipo_profesor? %>
      <div class="card">
        <div class="card-header">
          <h3 class="card-title">Clases asignadas (<%= @personal_deportivo.clases.count %>)</h3>
          <div class="card-options">
            <%= link_to new_admin_clase_path(personal_deportivo_id: @personal_deportivo.id), class: "btn btn-sm btn-primary" do %>
              <i class="ti ti-plus"></i> Nueva clase
            <% end %>
          </div>
        </div>
        <% if @personal_deportivo.clases.any? %>
          <div class="table-responsive">
            <table class="table table-vcenter card-table table-sm">
              <thead><tr><th>Clase</th><th>Horario</th><th>Alumnos</th><th>Estado</th></tr></thead>
              <tbody>
                <% @personal_deportivo.clases.order(:scheduled_at).each do |clase| %>
                  <tr>
                    <td><%= link_to clase.nombre, admin_clase_path(clase), class: "fw-semibold text-reset" %></td>
                    <td class="text-muted small"><%= clase.schedule_label %></td>
                    <td class="text-muted small"><%= clase.spots_taken %> / <%= clase.max_students %></td>
                    <td><span class="badge <%= clase.activa? ? 'bg-success-lt' : 'bg-secondary-lt' %>"><%= clase.activa? ? "Activa" : "Inactiva" %></span></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="card-body text-muted small">Sin clases asignadas.</div>
        <% end %>
      </div>
    <% end %>

    <% if @personal_deportivo.tipo_entrenador? %>
      <div class="card">
        <div class="card-header">
          <h3 class="card-title">Entrenamientos asignados (<%= @personal_deportivo.entrenamientos.count %>)</h3>
          <div class="card-options">
            <%= link_to new_admin_entrenamiento_path(personal_deportivo_id: @personal_deportivo.id), class: "btn btn-sm btn-primary" do %>
              <i class="ti ti-plus"></i> Nuevo entrenamiento
            <% end %>
          </div>
        </div>
        <% if @personal_deportivo.entrenamientos.any? %>
          <div class="table-responsive">
            <table class="table table-vcenter card-table table-sm">
              <thead><tr><th>Entrenamiento</th><th>Horario</th><th>Inscriptos</th><th>Estado</th></tr></thead>
              <tbody>
                <% @personal_deportivo.entrenamientos.order(:scheduled_at).each do |ent| %>
                  <tr>
                    <td><%= link_to ent.nombre, admin_entrenamiento_path(ent), class: "fw-semibold text-reset" %></td>
                    <td class="text-muted small"><%= ent.schedule_label %></td>
                    <td class="text-muted small"><%= ent.spots_taken %> / <%= ent.max_students %></td>
                    <td><span class="badge <%= ent.activo? ? 'bg-success-lt' : 'bg-secondary-lt' %>"><%= ent.activo? ? "Activo" : "Inactivo" %></span></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="card-body text-muted small">Sin entrenamientos asignados.</div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
