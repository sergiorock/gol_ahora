<% content_for :page_title, "Ligas" %>
<% content_for :header_actions do %>
  <%= link_to new_admin_league_path, class: "btn btn-primary" do %>
    <i class="ti ti-plus"></i> Nueva liga
  <% end %>
<% end %>

<% if @current.any? %>
  <div class="card mb-4">
    <div class="card-header"><h3 class="card-title">Ligas activas</h3></div>
    <%= render "table", leagues: @current %>
  </div>
<% end %>

<% if @historical.any? %>
  <div class="card">
    <div class="card-header"><h3 class="card-title text-muted">Historial</h3></div>
    <%= render "table", leagues: @historical %>
  </div>
<% end %>

<% if @current.empty? && @historical.empty? %>
  <div class="card"><div class="card-body text-center text-muted py-5">No hay ligas registradas.</div></div>
<% end %>
