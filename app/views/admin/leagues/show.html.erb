<% content_for :page_title, @league.name %>
<% content_for :header_actions do %>
  <%= link_to admin_leagues_path, class: "btn btn-secondary" do %><i class="ti ti-arrow-left"></i> Volver<% end %>
  <%= link_to edit_admin_league_path(@league), class: "btn btn-warning" do %><i class="ti ti-pencil"></i> Editar<% end %>
  <%= link_to new_admin_league_match_path(@league), class: "btn btn-primary" do %><i class="ti ti-plus"></i> Agregar partido<% end %>
  <%= link_to new_admin_league_enrollment_path(@league), class: "btn btn-primary" do %><i class="ti ti-user-plus"></i> Inscribir equipo<% end %>
<% end %>

<div class="row g-4">
  <div class="col-lg-4">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">Datos de la liga</h3>
        <div class="card-options"><%= league_status_badge(@league.status) %></div>
      </div>
      <div class="card-body">
        <dl class="row g-2">
          <% if @league.start_date %>
            <dt class="col-5 text-muted">Inicio</dt>
            <dd class="col-7"><%= l @league.start_date, format: :long %></dd>
          <% end %>
          <% if @league.end_date %>
            <dt class="col-5 text-muted">Fin</dt>
            <dd class="col-7"><%= l @league.end_date, format: :long %></dd>
          <% end %>
          <% if @league.description.present? %>
            <dt class="col-5 text-muted">Descripción</dt>
            <dd class="col-7"><%= @league.description %></dd>
          <% end %>
        </dl>
        <% if @league.rules.present? %>
          <div class="mt-3">
            <div class="text-muted small fw-semibold mb-1">Reglamento</div>
            <div class="small"><%= simple_format @league.rules %></div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-8">
    <div class="card mb-3">
      <div class="card-header">
        <h3 class="card-title">Equipos inscriptos (<%= @league.enrollments.active.count %>)</h3>
      </div>
      <% enrollments = @league.enrollments.includes(:user).order(:team_name) %>
      <% if enrollments.any? %>
        <div class="table-responsive">
          <table class="table table-vcenter card-table table-sm">
            <thead><tr><th>Equipo</th><th>Capitán</th><th>Inscripto</th><th>Estado</th><th class="w-1"></th></tr></thead>
            <tbody>
              <% enrollments.each do |e| %>
                <tr>
                  <td class="fw-semibold"><%= e.team_name %></td>
                  <td class="text-muted small"><%= e.user.full_name %></td>
                  <td class="text-muted small"><%= l e.enrolled_at, format: "%-d/%m/%Y" %></td>
                  <td><span class="badge <%= e.active? ? 'bg-primary-lt' : 'bg-secondary-lt' %>"><%= e.active? ? 'Activa' : 'Cancelada' %></span></td>
                  <td>
                    <div class="d-flex gap-1">
                      <%= link_to edit_admin_league_enrollment_path(@league, e), class: "btn btn-sm btn-ghost-warning" do %><i class="ti ti-pencil"></i><% end %>
                      <%= button_to admin_league_enrollment_path(@league, e), method: :delete, class: "btn btn-sm btn-ghost-danger", data: { confirm: "¿Eliminar inscripción?" } do %><i class="ti ti-trash"></i><% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="card-body text-muted small">Sin equipos inscriptos.</div>
      <% end %>
    </div>

    <div class="card">
      <div class="card-header"><h3 class="card-title">Fixture / Partidos</h3></div>
      <%= render "admin/matches/table", matches: @matches, competition: @league, competition_type: :league %>
    </div>
  </div>
</div>
