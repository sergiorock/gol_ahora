<div class="table-responsive">
  <table class="table table-vcenter card-table">
    <thead>
      <tr><th>Nombre</th><th>Fechas</th><th>Estado</th><th>Partidos</th><th class="w-1">Acciones</th></tr>
    </thead>
    <tbody>
      <% leagues.each do |league| %>
        <tr>
          <td class="fw-semibold"><%= league.name %></td>
          <td class="text-muted small">
            <% if league.start_date %>
              <%= l league.start_date, format: "%-d/%m/%Y" %>
              <% if league.end_date %> → <%= l league.end_date, format: "%-d/%m/%Y" %><% end %>
            <% else %>—<% end %>
          </td>
          <td><%= league_status_badge(league.status) %></td>
          <td class="text-muted"><%= league.matches.count %></td>
          <td>
            <div class="d-flex gap-1">
              <%= link_to admin_league_path(league), class: "btn btn-sm btn-ghost-secondary" do %><i class="ti ti-eye"></i><% end %>
              <%= link_to edit_admin_league_path(league), class: "btn btn-sm btn-ghost-warning" do %><i class="ti ti-pencil"></i><% end %>
              <%= button_to admin_league_path(league), method: :delete, class: "btn btn-sm btn-ghost-danger", data: { confirm: "¿Eliminar liga?" } do %><i class="ti ti-trash"></i><% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
