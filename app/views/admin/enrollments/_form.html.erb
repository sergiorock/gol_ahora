<%= simple_form_for [:admin, competition, enrollment] do |f| %>
  <% if enrollment.errors.any? %>
    <div class="alert alert-danger"><ul class="mb-0"><% enrollment.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul></div>
  <% end %>
  <div class="row g-3">
    <div class="col-md-6">
      <%= f.input :user_id, label: "Capitán / Representante",
            collection: @users, value_method: :id,
            label_method: ->(u) { "#{u.full_name} — #{u.email}" },
            include_blank: "Seleccioná un usuario" %>
    </div>
    <div class="col-md-6">
      <%= f.input :team_name, label: "Nombre del equipo", placeholder: "Ej: Los Pumas FC" %>
    </div>
    <% if enrollment.persisted? %>
      <div class="col-md-4">
        <%= f.input :status, label: "Estado",
              collection: [["Activa", "active"], ["Cancelada", "cancelled"]],
              include_blank: false %>
      </div>
    <% end %>
  </div>
  <div class="d-flex gap-2 mt-3">
    <%= f.button :submit, enrollment.persisted? ? "Guardar cambios" : "Registrar inscripción", class: "btn btn-primary" %>
    <%= link_to "Cancelar", competition_type == :league ? admin_league_path(competition) : admin_tournament_path(competition), class: "btn btn-ghost-secondary" %>
  </div>
<% end %>
