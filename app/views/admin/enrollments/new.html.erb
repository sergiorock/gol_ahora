<% comp_name = @competition_type == :league ? "Liga" : "Torneo" %>
<% content_for :page_title, "Nueva inscripción — #{@competition.name}" %>
<% content_for :header_actions do %>
  <%= link_to @competition_type == :league ? admin_league_path(@competition) : admin_tournament_path(@competition), class: "btn btn-secondary" do %><i class="ti ti-arrow-left"></i> Volver<% end %>
<% end %>
<div class="row justify-content-center"><div class="col-lg-7"><div class="card"><div class="card-header"><h3 class="card-title"><%= @competition.name %></h3></div><div class="card-body"><%= render "form", enrollment: @enrollment, competition: @competition, competition_type: @competition_type %></div></div></div></div>
