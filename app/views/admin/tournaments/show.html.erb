<% content_for :page_title, @tournament.name %>
<% content_for :header_actions do %>
  <%= link_to admin_tournaments_path, class: "btn btn-secondary" do %><i class="ti ti-arrow-left"></i> Volver<% end %>
  <%= link_to edit_admin_tournament_path(@tournament), class: "btn btn-warning" do %><i class="ti ti-pencil"></i> Editar<% end %>
  <%= link_to new_admin_tournament_match_path(@tournament), class: "btn btn-primary" do %><i class="ti ti-plus"></i> Agregar partido<% end %>
<% end %>

<div class="row g-4">
  <div class="col-lg-4">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">Datos del torneo</h3>
        <div class="card-options"><%= tournament_status_badge(@tournament.status) %></div>
      </div>
      <div class="card-body">
        <dl class="row g-2">
          <dt class="col-5 text-muted">Formato</dt>
          <dd class="col-7"><span class="badge bg-blue-lt"><%= Tournament::FORMAT_LABELS[@tournament.format] %></span></dd>
          <% if @tournament.start_date %>
            <dt class="col-5 text-muted">Inicio</dt>
            <dd class="col-7"><%= l @tournament.start_date, format: :long %></dd>
          <% end %>
          <% if @tournament.end_date %>
            <dt class="col-5 text-muted">Fin</dt>
            <dd class="col-7"><%= l @tournament.end_date, format: :long %></dd>
          <% end %>
          <% if @tournament.description.present? %>
            <dt class="col-5 text-muted">Descripción</dt>
            <dd class="col-7"><%= @tournament.description %></dd>
          <% end %>
        </dl>
        <% if @tournament.rules.present? %>
          <div class="mt-3">
            <div class="text-muted small fw-semibold mb-1">Reglamento</div>
            <div class="small"><%= simple_format @tournament.rules %></div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-8">
    <div class="card">
      <div class="card-header"><h3 class="card-title">Fixture / Partidos</h3></div>
      <%= render "admin/matches/table", matches: @matches, competition: @tournament, competition_type: :tournament %>
    </div>
  </div>
</div>
