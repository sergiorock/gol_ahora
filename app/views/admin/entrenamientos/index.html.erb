<% content_for :page_title, "Entrenamientos" %>
<% content_for :header_actions do %>
  <%= link_to new_admin_entrenamiento_path, class: "btn btn-primary" do %>
    <i class="ti ti-plus"></i> Nuevo entrenamiento
  <% end %>
<% end %>

<div class="card">
  <div class="table-responsive">
    <table class="table table-vcenter card-table">
      <thead>
        <tr>
          <th>Entrenamiento</th>
          <th>Entrenador</th>
          <th>Horario</th>
          <th>Duración</th>
          <th>Inscriptos</th>
          <th>Estado</th>
          <th class="w-1">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% @entrenamientos.each do |ent| %>
          <tr>
            <td>
              <%= link_to admin_entrenamiento_path(ent), class: "fw-semibold text-reset" do %>
                <%= ent.nombre %>
              <% end %>
            </td>
            <td class="text-muted small"><%= ent.personal_deportivo.full_name %></td>
            <td class="text-muted small"><%= ent.schedule_label %></td>
            <td class="text-muted small"><%= ent.duration_minutes %> min</td>
            <td>
              <% pct = ent.max_students > 0 ? (ent.spots_taken * 100 / ent.max_students) : 0 %>
              <div class="d-flex align-items-center gap-2">
                <span class="text-muted small"><%= ent.spots_taken %>/<%= ent.max_students %></span>
                <div class="progress progress-sm flex-grow-1" style="width:60px">
                  <div class="progress-bar <%= pct >= 100 ? 'bg-danger' : pct >= 70 ? 'bg-warning' : 'bg-primary' %>"
                       style="width:<%= pct %>%"></div>
                </div>
              </div>
            </td>
            <td>
              <span class="badge <%= ent.activo? ? 'bg-primary-lt' : 'bg-secondary-lt' %>">
                <%= ent.activo? ? "Activo" : "Inactivo" %>
              </span>
            </td>
            <td>
              <div class="btn-group">
                <%= link_to admin_entrenamiento_path(ent), class: "btn btn-sm btn-ghost-secondary" do %>
                  <i class="ti ti-eye"></i>
                <% end %>
                <%= link_to edit_admin_entrenamiento_path(ent), class: "btn btn-sm btn-ghost-warning" do %>
                  <i class="ti ti-pencil"></i>
                <% end %>
                <%= button_to admin_entrenamiento_path(ent), method: :delete,
                    form: { data: { confirm: "¿Eliminar #{ent.nombre}?" } },
                    class: "btn btn-sm btn-ghost-danger" do %>
                  <i class="ti ti-trash"></i>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
        <% if @entrenamientos.empty? %>
          <tr><td colspan="7" class="text-center text-muted py-4">Sin entrenamientos creados todavía.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
