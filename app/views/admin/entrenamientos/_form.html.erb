<%= simple_form_for [:admin, entrenamiento] do |f| %>
  <div class="card">
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-8">
          <%= f.input :nombre, label: "Nombre del entrenamiento", placeholder: "Ej: Preparación física avanzada" %>
        </div>
        <div class="col-md-4">
          <%= f.input :status, label: "Estado",
              collection: [["Activo", "activo"], ["Inactivo", "inactivo"]],
              include_blank: false %>
        </div>
        <div class="col-md-6">
          <%= f.input :personal_deportivo_id, label: "Entrenador",
              collection: @personal_deportivos.map { |pd| [pd.full_name, pd.id] },
              include_blank: "Seleccioná un entrenador" %>
        </div>
        <div class="col-md-6">
          <%= f.input :scheduled_at, label: "Fecha y hora", as: :string,
              input_html: { type: "datetime-local", value: entrenamiento.scheduled_at&.strftime("%Y-%m-%dT%H:%M") } %>
        </div>
        <div class="col-md-3">
          <%= f.input :duration_minutes, label: "Duración (minutos)", placeholder: "90" %>
        </div>
        <div class="col-md-3">
          <%= f.input :max_students, label: "Cupo máximo", placeholder: "15" %>
        </div>
<div class="col-12">
          <%= f.input :descripcion, label: "Descripción", as: :text,
              input_html: { rows: 3 }, placeholder: "Descripción del entrenamiento..." %>
        </div>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2 mt-3">
    <%= f.button :submit, entrenamiento.persisted? ? "Guardar cambios" : "Crear entrenamiento", class: "btn btn-primary" %>
    <%= link_to "Cancelar", admin_entrenamientos_path, class: "btn btn-secondary" %>
  </div>
<% end %>
