<% content_for :page_title, "Bloquear — #{@court.name}" %>

<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">Registrar bloqueo de mantenimiento</h3>
      </div>
      <div class="card-body">
        <%= simple_form_for [:admin, @court, @block] do |f| %>
          <div class="row g-3">
            <div class="col-md-6">
              <%= f.input :starts_at, label: "Desde", as: :string,
                    input_html: { type: "datetime-local" } %>
            </div>
            <div class="col-md-6">
              <%= f.input :ends_at, label: "Hasta", as: :string,
                    input_html: { type: "datetime-local" } %>
            </div>
            <div class="col-12">
              <%= f.input :reason, label: "Motivo", placeholder: "Ej: Reparación del césped" %>
            </div>
          </div>
          <div class="d-flex gap-2 mt-3">
            <%= f.button :submit, "Registrar bloqueo", class: "btn btn-warning" %>
            <%= link_to "Cancelar", admin_court_path(@court), class: "btn btn-secondary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
