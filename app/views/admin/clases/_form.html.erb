<%= simple_form_for [:admin, clase] do |f| %>
  <div class="card">
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-8">
          <%= f.input :nombre, label: "Nombre de la clase", placeholder: "Ej: Fútbol para principiantes" %>
        </div>
        <div class="col-md-4">
          <%= f.input :status, label: "Estado",
              collection: [["Activa", "activa"], ["Inactiva", "inactiva"]],
              include_blank: false %>
        </div>
        <div class="col-md-6">
          <% if @personal_deportivos.empty? %>
            <div class="mb-3">
              <label class="form-label">Profesor</label>
              <div class="alert alert-warning py-2 mb-0 small">
                <i class="ti ti-alert-triangle me-1"></i>
                No existen profesores con certificación válida registrados en el sistema.
              </div>
            </div>
          <% else %>
            <%= f.input :personal_deportivo_id, label: "Profesor",
                collection: @personal_deportivos.map { |pd| [pd.full_name, pd.id] },
                include_blank: "Seleccioná un profesor" %>
          <% end %>
        </div>
        <div class="col-md-6">
          <%= f.input :court_type_id, label: "Tipo de cancha (opcional)",
              collection: @court_types.map { |ct| ["#{ct.name} — #{CourtType::SURFACE_LABELS[ct.surface]}", ct.id] },
              include_blank: "Sin asignar" %>
        </div>
        <div class="col-md-6">
          <%= f.input :scheduled_at, label: "Fecha y hora", as: :string,
              input_html: { type: "datetime-local", value: clase.scheduled_at&.strftime("%Y-%m-%dT%H:%M") } %>
        </div>
        <div class="col-md-3">
          <%= f.input :duration_minutes, label: "Duración (minutos)", placeholder: "60" %>
        </div>
        <div class="col-md-3">
          <%= f.input :max_students, label: "Cupo máximo", placeholder: "10" %>
        </div>
<div class="col-12">
          <%= f.input :descripcion, label: "Descripción", as: :text,
              input_html: { rows: 3 }, placeholder: "Descripción de la clase..." %>
        </div>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2 mt-3">
    <%= f.button :submit, clase.persisted? ? "Guardar cambios" : "Crear clase", class: "btn btn-primary" %>
    <%= link_to "Cancelar", admin_clases_path, class: "btn btn-secondary" %>
  </div>
<% end %>
